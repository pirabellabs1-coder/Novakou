# ============================================================
# FreelanceHigh — Variables d'environnement
# Copier ce fichier vers .env.local et remplir les valeurs
# ============================================================

# ── Base de données (Supabase) ──
# Obtenir depuis : supabase.com > Project Settings > Database
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Supabase Storage (fichiers prives : messages vocaux, KYC, livrables) ──
# Obtenir depuis : supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# ── TURN Servers (appels audio/video WebRTC) ──
# Obtenir gratuitement depuis : https://dashboard.metered.ca/ > App > TURN credentials
# Sans TURN, les appels ne marchent PAS entre réseaux différents (NAT)
NEXT_PUBLIC_TURN_URL="turn:a.relay.metered.ca:80,turn:a.relay.metered.ca:443,turn:a.relay.metered.ca:443?transport=tcp"
NEXT_PUBLIC_TURN_USERNAME=""
NEXT_PUBLIC_TURN_CREDENTIAL=""

# ── NextAuth ──
# Generer avec : openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ── Google OAuth ──
# Obtenir depuis : console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (Resend) ──
# Obtenir depuis : resend.com > API Keys
RESEND_API_KEY=""
EMAIL_FROM="FreelanceHigh <noreply@freelancehigh.com>"

# ── Stripe ──
# Obtenir depuis : dashboard.stripe.com > Developers > API Keys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Cloudinary ──
# Obtenir depuis : cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Google Analytics ──
# Obtenir depuis : analytics.google.com > Admin > Data Streams
NEXT_PUBLIC_GA_ID=""

# ── App ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FreelanceHigh"

# ── Admin initial ──
# Email et mot de passe du premier admin (utilise dans le seed)
ADMIN_EMAIL="admin@freelancehigh.com"
ADMIN_PASSWORD=""

# ── Token secret pour lien admin (NE JAMAIS partager) ──
# Generer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_ACCESS_TOKEN=""

# ── Vercel Domains API (custom domains vendeur/mentor) ──
# Token: https://vercel.com/account/tokens
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=prj_yrEh7fL2HKqFPK8lAsEw2dpnWPDy
VERCEL_TEAM_ID=team_IHEGjbCN0XXQNhSHtEFdJHJi
