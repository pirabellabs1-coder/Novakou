// FreelanceHigh — Prisma Schema (Production)
// Source unique de verite pour tous les types DB

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──

enum UserRole {
  FREELANCE
  CLIENT
  AGENCE
  ADMIN
}

enum UserPlan {
  GRATUIT
  PRO
  BUSINESS
  AGENCE
}

enum UserStatus {
  ACTIF
  SUSPENDU
  BANNI
}

enum ServiceStatus {
  BROUILLON
  EN_ATTENTE
  ACTIF
  PAUSE
  REFUSE
  VEDETTE
}

enum OrderStatus {
  EN_ATTENTE
  EN_COURS
  LIVRE
  REVISION
  TERMINE
  ANNULE
  LITIGE
}

enum EscrowStatus {
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

enum PaymentStatus {
  EN_ATTENTE
  COMPLETE
  ECHOUE
  REMBOURSE
}

enum PaymentMethod {
  CARTE
  MOBILE_MONEY
  VIREMENT
  PAYPAL
  STRIPE
}

enum DisputeStatus {
  OUVERT
  EN_EXAMEN
  RESOLU
}

enum DisputeVerdict {
  CLIENT
  FREELANCE
  PARTIEL
  ANNULATION
}

enum ConversationType {
  DIRECT
  GROUP
  ORDER
  ADMIN
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
  VOICE
  CALL_AUDIO
  CALL_VIDEO
  CALL_MISSED
}

enum NotificationType {
  ADMIN_ACTION
  MESSAGE
  ORDER
  KYC
  SYSTEM
  PAYMENT
}

enum KycStatus {
  EN_ATTENTE
  APPROUVE
  REFUSE
}

enum BlogStatus {
  BROUILLON
  PROGRAMME
  PUBLIE
}

enum BidStatus {
  EN_ATTENTE
  ACCEPTE
  REFUSE
  EXPIRE
}

enum ContractStatus {
  BROUILLON
  ENVOYE
  SIGNE
  EXPIRE
  ANNULE
}

enum AutomationStatus {
  ACTIF
  PAUSE
  BROUILLON
}

// ── OTP Codes ──

model OtpCode {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ── Models ──

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String
  name          String
  image         String?
  role          UserRole   @default(FREELANCE)
  plan          UserPlan   @default(GRATUIT)
  status        UserStatus @default(ACTIF)
  country       String?
  countryFlag   String?
  phone         String?
  avatar        String?
  kyc           Int        @default(1)
  suspendReason String?

  // 2FA
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // Formations
  formationsRole String? // "apprenant" ou "instructeur"

  // Tracking
  lastLoginAt DateTime?
  lastLoginIp String?
  loginCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts            Account[]
  sessions            Session[]
  deletionRequest     AccountDeletionRequest? @relation("UserDeletionRequest")
  auditLogsAsActor    AuditLog[]           @relation("AuditActor")
  auditLogsAsTarget   AuditLog[]           @relation("AuditTarget")
  messages            Message[]
  notifications       Notification[]
  conversationUsers   ConversationUser[]
  loginAttempts       LoginAttempt[]
  freelancerProfile   FreelancerProfile?
  clientProfile       ClientProfile?
  agencyProfile       AgencyProfile?
  services            Service[]
  ordersAsClient      Order[]              @relation("OrderClient")
  ordersAsFreelance   Order[]              @relation("OrderFreelance")
  reviewsGiven        Review[]             @relation("ReviewAuthor")
  reviewsReceived     Review[]             @relation("ReviewTarget")
  paymentsAsPayer     Payment[]            @relation("PaymentPayer")
  paymentsAsPayee     Payment[]            @relation("PaymentPayee")
  bids                Bid[]
  contractsSigned     ContractSignature[]
  automations         AutomationScenario[]
  affiliationCodes    AffiliationCode[]
  blogPosts           BlogPost[]
  kycRequests         KycRequest[]
  disputesAsClient    Dispute[]            @relation("DisputeClient")
  disputesAsFreelance Dispute[]            @relation("DisputeFreelance")

  // Relations formations
  instructeurProfile InstructeurProfile?
  enrollments        Enrollment[]             @relation("UserEnrollments")
  certificates       Certificate[]            @relation("UserCertificates")
  formationReviews   FormationReview[]        @relation("UserFormationReviews")
  cartItems          CartItem[]               @relation("UserCartItems")
  productPurchases   DigitalProductPurchase[] @relation("UserProductPurchases")
  productReviews     DigitalProductReview[]   @relation("UserProductReviews")
  abandonedCarts     AbandonedCart[]          @relation("UserAbandonedCarts")
  checkoutAttempts   CheckoutAttempt[]        @relation("UserCheckoutAttempts")
  marketingEvents    MarketingEvent[]         @relation("UserMarketingEvents")
  courseDiscussions  CourseDiscussion[]       @relation("UserDiscussions")
  discussionReplies  CourseDiscussionReply[]  @relation("UserDiscussionReplies")
  cohortMessages     CohortMessage[]          @relation("UserCohortMessages")

  // Relations marketing
  affiliateProfile    AffiliateProfile?         @relation("UserAffiliateProfile")
  affiliateClicks     AffiliateClick[]          @relation("UserAffiliateClicks")
  emailSeqEnrollments EmailSequenceEnrollment[] @relation("UserEmailSeqEnrollments")
  funnelEvents        FunnelEvent[]             @relation("UserFunnelEvents")
  popupImpressions    PopupImpression[]         @relation("UserPopupImpressions")
  campaignEvents      CampaignEvent[]           @relation("UserCampaignEvents")
  userTags            UserTag[]                 @relation("UserTags")
  refundRequests      RefundRequest[]           @relation("UserRefundRequests")
  discussionReports   DiscussionReport[]        @relation("UserDiscussionReports")
  subscriptions       Subscription[]            @relation("UserSubscriptions")

  // Mentor relations
  mentorProfile  MentorProfile?  @relation("UserMentorProfile")
  mentorBookings MentorBooking[] @relation("UserMentorBookings")

  // Team / Collaborators
  shopMemberships ShopMember[]       @relation("UserShopMemberships")
  shopInvitesSent ShopInvitation[]   @relation("UserShopInvitesSent")

  // Tracking
  registrationSource String?

  @@index([email])
  @@index([role])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model FreelancerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?  @db.Text
  title           String?
  skills          String[] @default([])
  hourlyRate      Float?
  availability    String? // "disponible", "occupe", "vacances"
  timezone        String?
  languages       String[] @default([])
  portfolio       Json? // Array d'objets { title, description, imageUrl, link }
  badges          String[] @default([])
  completionRate  Float    @default(0)
  avgResponseTime Int? // en minutes

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  company     String?
  sector      String?
  size        String? // "1-10", "11-50", "51-200", "200+"
  website     String?
  description String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgencyProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  agencyName  String
  logo        String?
  sector      String?
  size        String?
  description String? @db.Text
  website     String?
  siret       String?
  verified    Boolean @default(false)
  teamMembers Json? // Array d'objets { userId, role, joinedAt }

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id              String   @id @default(cuid())
  userId          String
  token           String   @unique
  ipAddress       String?
  userAgent       String?
  expiresAt       DateTime
  isImpersonation Boolean  @default(false)
  impersonatedBy  String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  icon        String?
  color       String?
  description String?
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  services    Service[]
  tags        Tag[]
  createdAt   DateTime   @default(now())

  @@index([slug])
  @@index([order])
}

enum MediaType {
  IMAGE
  VIDEO
}

model Service {
  id                   String        @id @default(cuid())
  title                String
  slug                 String        @unique
  language             String        @default("fr")
  description          Json? // Format Tiptap JSON
  descriptionText      String?       @db.Text // Texte brut pour la recherche FTS
  categoryId           String
  subCategoryId        String?
  userId               String
  agencyId             String?
  status               ServiceStatus @default(BROUILLON)
  basePrice            Float         @default(5)
  deliveryDays         Int           @default(7)
  revisions            Int           @default(1)
  instructionsRequired Boolean       @default(false)
  instructionsContent  Json? // Format Tiptap JSON
  draftData            Json? // Sauvegarde brouillon wizard complet
  draftStep            Int? // Derniere etape completee du wizard

  // Ancien champ prix conserve pour compatibilite
  price Float @default(5)

  // Legacy fields (migration progressive)
  tags     String[] @default([])
  images   String[] @default([])
  packages Json?
  faq      Json?
  extras   Json?

  // Stats
  views        Int       @default(0)
  orderCount   Int       @default(0)
  rating       Float     @default(0)
  ratingCount  Int       @default(0)
  isBoosted    Boolean   @default(false)
  boostedUntil DateTime?
  refuseReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category    Category        @relation(fields: [categoryId], references: [id])
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
  reviews     Review[]
  options     ServiceOption[]
  media       ServiceMedia[]
  serviceTags ServiceTag[]

  @@index([slug])
  @@index([categoryId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@index([agencyId])
}

model ServiceOption {
  id                   String  @id @default(cuid())
  serviceId            String
  title                String
  description          String?
  extraPrice           Float   @default(0)
  extraDays            Int     @default(0)
  isRecommended        Boolean @default(false)
  sortOrder            Int     @default(0)
  expressEnabled       Boolean @default(false)
  expressPrice         Float?
  expressDaysReduction Int?

  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([sortOrder])
}

model ServiceMedia {
  id        String    @id @default(cuid())
  serviceId String
  type      MediaType @default(IMAGE)
  url       String
  isPrimary Boolean   @default(false)
  sortOrder Int       @default(0)
  width     Int?
  height    Int?

  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([isPrimary])
}

model Tag {
  id         String  @id @default(cuid())
  name       String  @unique
  slug       String  @unique
  categoryId String?

  category Category?    @relation(fields: [categoryId], references: [id])
  services ServiceTag[]

  @@index([categoryId])
  @@index([slug])
}

model ServiceTag {
  serviceId String
  tagId     String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([serviceId, tagId])
  @@index([tagId])
}

model Order {
  id           String       @id @default(cuid())
  serviceId    String
  clientId     String
  freelanceId  String
  status       OrderStatus  @default(EN_ATTENTE)
  escrowStatus EscrowStatus @default(HELD)
  amount       Float
  commission   Float        @default(0)
  packageType  String? // "basic", "standard", "premium"
  requirements String?      @db.Text
  deadline     DateTime
  deliveredAt  DateTime?
  completedAt  DateTime?
  progress     Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service      Service       @relation(fields: [serviceId], references: [id])
  client       User          @relation("OrderClient", fields: [clientId], references: [id])
  freelance    User          @relation("OrderFreelance", fields: [freelanceId], references: [id])
  payments     Payment[]
  reviews      Review[]
  disputes     Dispute[]
  conversation Conversation?

  @@index([clientId])
  @@index([freelanceId])
  @@index([status])
  @@index([createdAt])
}

model Review {
  id            String  @id @default(cuid())
  orderId       String
  serviceId     String
  authorId      String
  targetId      String
  rating        Float
  comment       String? @db.Text
  response      String? @db.Text // reponse du freelance
  quality       Float?
  communication Float?
  timeliness    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  author  User    @relation("ReviewAuthor", fields: [authorId], references: [id])
  target  User    @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([orderId, authorId])
  @@index([targetId])
  @@index([serviceId])
}

model Payment {
  id              String         @id @default(cuid())
  orderId         String?
  payerId         String
  payeeId         String?
  amount          Float
  currency        String         @default("EUR")
  status          PaymentStatus  @default(EN_ATTENTE)
  method          PaymentMethod?
  stripePaymentId String?
  description     String?
  type            String         @default("paiement") // paiement, commission, retrait, remboursement, abonnement

  createdAt DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id])
  payer User   @relation("PaymentPayer", fields: [payerId], references: [id])
  payee User?  @relation("PaymentPayee", fields: [payeeId], references: [id])

  @@index([orderId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
}

model Dispute {
  id                String          @id @default(cuid())
  orderId           String
  clientId          String
  freelanceId       String
  reason            String
  clientArgument    String?         @db.Text
  freelanceArgument String?         @db.Text
  status            DisputeStatus   @default(OUVERT)
  verdict           DisputeVerdict?
  verdictNote       String?
  partialPercent    Int?
  resolvedAt        DateTime?

  createdAt DateTime @default(now())

  order     Order @relation(fields: [orderId], references: [id])
  client    User  @relation("DisputeClient", fields: [clientId], references: [id])
  freelance User  @relation("DisputeFreelance", fields: [freelanceId], references: [id])

  @@index([status])
  @@index([orderId])
}

model Bid {
  id           String    @id @default(cuid())
  userId       String
  projectId    String? // reference a un projet client (future table)
  proposal     String?   @db.Text
  amount       Float
  deliveryDays Int
  status       BidStatus @default(EN_ATTENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Contract {
  id        String         @id @default(cuid())
  title     String
  content   String         @db.Text
  orderId   String?
  status    ContractStatus @default(BROUILLON)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  signatures ContractSignature[]
}

model ContractSignature {
  id         String   @id @default(cuid())
  contractId String
  userId     String
  signedAt   DateTime @default(now())
  ipAddress  String?

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([contractId, userId])
}

model AutomationScenario {
  id             String           @id @default(cuid())
  userId         String
  name           String
  trigger        String // "order_accepted", "deadline_24h", "client_inactive_3d"
  conditions     Json? // conditions supplementaires
  actions        Json // actions a executer
  status         AutomationStatus @default(BROUILLON)
  planRequired   UserPlan         @default(PRO) // plan minimum requis
  executionCount Int              @default(0)
  lastExecutedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AffiliationCode {
  id          String  @id @default(cuid())
  userId      String
  code        String  @unique
  commission  Float   @default(10) // pourcentage
  tier        String  @default("standard") // standard, premium
  usageCount  Int     @default(0)
  totalEarned Float   @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     String     @db.Text
  excerpt     String?
  coverImage  String?
  category    String?
  tags        String[]   @default([])
  authorId    String
  status      BlogStatus @default(BROUILLON)
  publishedAt DateTime?
  scheduledAt DateTime?
  views       Int        @default(0)

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
}

model KycRequest {
  id             String    @id @default(cuid())
  userId         String
  requestedLevel Int
  currentLevel   Int
  documentType   String
  documentUrl    String?
  status         KycStatus @default(EN_ATTENTE)
  reviewedBy     String?
  reviewedAt     DateTime?
  refuseReason   String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id           String  @id @default(cuid())
  actorId      String
  action       String
  targetType   String?
  targetId     String?
  targetUserId String?
  details      Json?
  ipAddress    String?

  createdAt DateTime @default(now())

  actor      User  @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model Conversation {
  id      String           @id @default(cuid())
  type    ConversationType @default(DIRECT)
  title   String?
  orderId String?          @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order    Order?             @relation(fields: [orderId], references: [id])
  users    ConversationUser[]
  messages Message[]

  @@index([type])
}

model ConversationUser {
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  content        String      @db.Text
  type           MessageType @default(TEXT)
  fileName       String?
  fileUrl        String?
  fileType       String?
  fileSizeBytes  Int?
  audioUrl       String?
  audioDuration  Int?
  callDuration   Int?
  read           Boolean     @default(false)

  editedAt        DateTime?
  deletedAt       DateTime?
  linkPreviewData Json?

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  title   String
  message String
  type    NotificationType @default(SYSTEM)
  read    Boolean          @default(false)
  link    String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

// ══════════════════════════════════════════════════════════════
// FORMATIONS PLATFORM
// ══════════════════════════════════════════════════════════════

// ── Enums formations ──

enum FormationLevel {
  DEBUTANT
  INTERMEDIAIRE
  AVANCE
  TOUS_NIVEAUX
}

enum LessonType {
  VIDEO
  PDF
  TEXTE
  AUDIO
  QUIZ
}

enum QuestionType {
  CHOIX_UNIQUE
  CHOIX_MULTIPLE
  VRAI_FAUX
  TEXTE_LIBRE
}

enum FormationStatus {
  BROUILLON
  EN_ATTENTE
  ACTIF
  ARCHIVE
}

enum CohortStatus {
  OUVERT
  COMPLET
  EN_COURS
  TERMINE
  ANNULE
}

enum InstructeurStatus {
  EN_ATTENTE
  APPROUVE
  SUSPENDU
}

// ── Models formations ──

model FormationCategory {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  icon     String?
  color    String?
  order    Int     @default(0)
  isActive Boolean @default(true)

  formations      Formation[]
  digitalProducts DigitalProduct[] @relation("CategoryProducts")

  createdAt DateTime @default(now())

  @@index([slug])
  @@index([order])
}

model InstructeurProfile {
  id          String            @id @default(cuid())
  userId      String            @unique
  bioFr       String?           @db.Text
  bioEn       String?           @db.Text
  expertise   String[]          @default([])
  linkedin    String?
  website     String?
  youtube     String?
  motivation  String?           @db.Text
  yearsExp    Int               @default(0)
  totalEarned Float             @default(0)
  status      InstructeurStatus @default(EN_ATTENTE)

  // Boutique publique (custom domain)
  shopSlug             String?   @unique
  customDomain         String?   @unique
  customDomainVerified Boolean   @default(false)
  customDomainAddedAt  DateTime?

  // Méthodes de paiement ACCEPTÉES par le vendeur à l'achat de ses produits.
  // Valeurs possibles : "orange_money" | "wave" | "mtn_momo" | "moov_money"
  // | "card" | "moneroo" | "stripe" | "paypal" | "bank_transfer" | "free"
  // Par défaut on active toutes les méthodes Mobile Money africaines + cartes
  // via Moneroo. Si vide, le vendeur accepte ce que la plateforme supporte.
  acceptedPaymentMethods String[] @default(["orange_money","wave","mtn_momo","moov_money","card"])

  // Méthodes de retrait configurées par le vendeur (liste de comptes pour
  // recevoir son argent). Exemple :
  //  [{"id":"...","method":"orange_money","label":"Personnel","phone":"+221771234567","primary":true},
  //   {"id":"...","method":"bank_transfer","label":"Ecobank","iban":"SN12...","primary":false}]
  payoutMethods Json?

  // AI Support Client — chatbot public sur la boutique du vendeur.
  // Le vendeur active, fournit un contexte (FAQ, politiques, infos produits)
  // et le widget apparait sur ses pages publiques. Claude via Puter.js
  // repond aux visiteurs avec ce contexte.
  supportAiEnabled Boolean @default(false)
  supportAiWelcome String? @db.Text // Message d'accueil du chatbot
  supportAiContext String? @db.Text // Contexte d'entrainement (max ~8000 chars)
  supportAiColor   String? // Couleur du widget (#hex), defaut = Novakou green

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  formations      Formation[]
  withdrawals     InstructorWithdrawal[] @relation("InstructeurWithdrawals")
  digitalProducts DigitalProduct[]       @relation("InstructeurProducts")
  marketingPixels MarketingPixel[]       @relation("InstructeurPixels")
  shops           VendorShop[]           @relation("InstructeurShops")

  // Marketing relations
  affiliatePrograms   AffiliateProgram[]   @relation("InstructeurAffiliatePrograms")
  discountCodes       DiscountCode[]       @relation("InstructeurDiscountCodes")
  emailSequences      EmailSequence[]      @relation("InstructeurEmailSequences")
  salesFunnels        SalesFunnel[]        @relation("InstructeurSalesFunnels")
  smartPopups         SmartPopup[]         @relation("InstructeurSmartPopups")
  campaignTrackers    CampaignTracker[]    @relation("InstructeurCampaignTrackers")
  automationWorkflows AutomationWorkflow[] @relation("InstructeurAutomationWorkflows")
  integrations        VendorIntegration[]  @relation("InstructeurIntegrations")
  webhooks            VendorWebhook[]      @relation("InstructeurWebhooks")
  apiKeys             VendorApiKey[]       @relation("InstructeurApiKeys")
  bundles             ProductBundle[]
  orderBumps          OrderBump[]          @relation("InstructeurOrderBumps")
  subscriptionPlans   SubscriptionPlan[]   @relation("InstructeurPlans")
  productInquiries    ProductInquiry[]     @relation("InstructeurInquiries")
  checkoutAttempts    CheckoutAttempt[]    @relation("InstructeurCheckoutAttempts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([customDomain])
}

/// VendorShop — multi-shop pour vendeur (max 5 par instructeur, validé côté API).
/// Chaque shop a son URL/domaine/nom propre. Le catalogue produits reste partagé
/// via instructeurId (les produits du vendeur s'affichent dans toutes ses boutiques).
model VendorShop {
  id                    String    @id @default(cuid())
  instructeurId         String
  name                  String
  slug                  String    @unique
  description           String?   @db.Text
  logoUrl               String?
  coverUrl              String?   // photo de couverture (hero/bannière) par boutique
  themeColor            String?   // hex e.g. "#006e2f"
  isPrimary             Boolean   @default(false)

  // Custom domain (par boutique)
  customDomain         String?    @unique
  customDomainVerified Boolean    @default(false)
  customDomainAddedAt  DateTime?

  instructeur InstructeurProfile @relation("InstructeurShops", fields: [instructeurId], references: [id], onDelete: Cascade)
  formations  Formation[]        @relation("ShopFormations")
  products    DigitalProduct[]   @relation("ShopProducts")
  bundles     ProductBundle[]
  members     ShopMember[]       @relation("ShopMemberships")
  invitations ShopInvitation[]   @relation("ShopInvitations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructeurId])
  @@index([slug])
  @@index([customDomain])
}

/// Rôle d'un membre dans une boutique :
///  - OWNER   : propriétaire original (crée la boutique). Seul rôle qui peut faire des retraits.
///  - MANAGER : peut inviter d'autres membres, gérer produits, voir stats. Ne peut pas retirer.
///  - EDITOR  : peut gérer produits uniquement (création/édition/publication). Ne peut pas inviter ni retirer.
enum ShopMemberRole {
  OWNER
  MANAGER
  EDITOR
}

/// Liaison user ↔ boutique. Un user peut être membre de plusieurs boutiques
/// (chez des vendeurs différents) tout en gardant son propre compte.
model ShopMember {
  id         String         @id @default(cuid())
  shopId     String
  shop       VendorShop     @relation("ShopMemberships", fields: [shopId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation("UserShopMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role       ShopMemberRole @default(EDITOR)
  invitedBy  String?        // userId de la personne qui a invité (null si OWNER)
  createdAt  DateTime       @default(now())

  @@unique([shopId, userId])
  @@index([userId])
  @@index([shopId, role])
}

/// Invitations en attente. Quand un vendeur invite un email :
///  - si l'email existe déjà chez Novakou, la personne peut accepter en étant connectée
///  - sinon elle crée d'abord un compte (mot de passe + email), puis accepte.
/// Le code d'invitation est unique, à inclure dans l'URL envoyée par email.
model ShopInvitation {
  id         String         @id @default(cuid())
  shopId     String
  shop       VendorShop     @relation("ShopInvitations", fields: [shopId], references: [id], onDelete: Cascade)
  email      String
  role       ShopMemberRole @default(EDITOR)
  inviteCode String         @unique @default(cuid())
  invitedBy  String?        // userId de l'inviteur
  inviter    User?          @relation("UserShopInvitesSent", fields: [invitedBy], references: [id], onDelete: SetNull)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([email])
  @@index([inviteCode])
  @@index([shopId])
}

model Formation {
  id   String @id @default(cuid())
  slug String @unique

  // Contenu (langue unique, détectée par locale)
  title          String
  shortDesc      String?
  description    String?  @db.Text
  learnPoints    String[] @default([])
  requirements   String[] @default([])
  targetAudience String?  @db.Text
  locale         String   @default("fr")
  customCategory String?

  // Médias
  thumbnail    String?
  previewVideo String?

  // Catégorie
  categoryId  String
  subCategory String?

  // Infos
  level    FormationLevel @default(TOUS_NIVEAUX)
  language String[]       @default(["fr"])
  duration Int            @default(0) // minutes total

  // Prix
  price         Float   @default(0)
  originalPrice Float?
  isFree        Boolean @default(false)

  // Certificat
  hasCertificate   Boolean @default(true)
  minScore         Int     @default(80)
  requireFinalQuiz Boolean @default(false)

  // Stock limité & Promotions flash
  maxStudents       Int? // null = illimité
  discountStartAt   DateTime?
  discountEndAt     DateTime?
  descriptionFormat String    @default("text") // "text" | "tiptap"

  // Cohortes
  isGroupFormation Boolean @default(false)

  // Stats
  studentsCount Int   @default(0)
  rating        Float @default(0)
  reviewsCount  Int   @default(0)
  viewsCount    Int   @default(0)

  // Statut
  status       FormationStatus @default(BROUILLON)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  refuseReason String?

  // Visibilité — true = exclusivement dans la boutique du vendeur, pas dans /explorer
  hiddenFromMarketplace Boolean @default(false)

  // Multi-shop : à quelle boutique du vendeur appartient ce produit
  shopId String?
  shop   VendorShop? @relation("ShopFormations", fields: [shopId], references: [id], onDelete: SetNull)

  // Wizard brouillon
  draftStep Int?

  // Relations
  instructeurId   String
  instructeur     InstructeurProfile @relation(fields: [instructeurId], references: [id], onDelete: Cascade)
  category        FormationCategory  @relation(fields: [categoryId], references: [id])
  sections        Section[]
  enrollments     Enrollment[]
  reviews         FormationReview[]
  certificates    Certificate[]
  cartItems       CartItem[]
  flashPromotions FlashPromotion[]   @relation("FormationFlashPromos")
  marketingEvents MarketingEvent[]   @relation("FormationMarketingEvents")
  discussions     CourseDiscussion[]
  cohorts         FormationCohort[]
  salesPage       SalesPage?
  bundleItems     ProductBundleItem[]
  quiz            FormationQuiz?
  orderBumpsAsBump OrderBump[]       @relation("BumpFormation")
  inquiries        ProductInquiry[]
  checkoutAttempts CheckoutAttempt[] @relation("FormationCheckoutAttempts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([instructeurId])
  @@index([status])
  @@index([rating])
  @@index([createdAt])
  @@index([studentsCount])
  @@index([price])
  @@index([isFree])
}

model SalesPage {
  id           String    @id @default(cuid())
  formationId  String    @unique
  instructorId String
  slug         String    @unique
  blocks       Json      @default("[]") // Array de blocs typés
  published    Boolean   @default(false)
  formation    Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([instructorId])
}

model Section {
  id          String    @id @default(cuid())
  title       String
  desc        String?
  order       Int       @default(0)
  formationId String
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@index([formationId, order])
}

model Lesson {
  id                  String           @id @default(cuid())
  title               String
  desc                String?          @db.Text
  type                LessonType       @default(VIDEO)
  content             String?          @db.Text // Pour les leçons TEXTE (HTML rich text)
  videoUrl            String? // URL YouTube/Vimeo ou URL signée Supabase
  videoStoragePath    String? // Chemin dans Supabase Storage
  pdfUrl              String?
  pdfStoragePath      String?
  audioUrl            String?
  audioStoragePath    String?
  subtitleUrl         String? // URL publique du fichier .vtt
  subtitleStoragePath String? // Chemin dans Supabase Storage
  subtitleLabel       String? // Ex: "Français", "English"
  chapters            Json? // [{title, timestamp}] pour navigation vidéo
  duration            Int? // minutes
  order               Int              @default(0)
  isFree              Boolean          @default(false)
  allowDownload       Boolean          @default(false) // pour PDF/audio
  sectionId           String
  section             Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  resources           LessonResource[]
  quiz                Quiz?
  progress            LessonProgress[]
  notes               LessonNote[]

  @@index([sectionId, order])
}

model LessonResource {
  id       String  @id @default(cuid())
  lessonId String
  name     String
  url      String
  fileSize Int? // bytes
  mimeType String?
  lesson   Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Quiz {
  id           String     @id @default(cuid())
  title        String
  passingScore Int        @default(80)
  timeLimit    Int? // minutes, null = pas de limite
  lessonId     String     @unique
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions    Question[]

  @@index([lessonId])
}

model Question {
  id            String       @id @default(cuid())
  text          String       @db.Text
  type          QuestionType @default(CHOIX_UNIQUE)
  options       Json // Array of { text, value }
  correctAnswer String // valeur(s) correcte(s) — JSON array pour CHOIX_MULTIPLE
  explanation   String?      @db.Text
  order         Int          @default(0)
  quizId        String
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, order])
}

model Enrollment {
  id              String    @id @default(cuid())
  userId          String
  formationId     String
  cohortId        String?
  progress        Float     @default(0) // 0-100%
  completedAt     DateTime?
  paidAmount      Float     @default(0)
  stripeSessionId String?
  refundRequested Boolean   @default(false)
  refundReason    String?
  refundedAt      DateTime?

  user           User             @relation("UserEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  formation      Formation        @relation(fields: [formationId], references: [id], onDelete: Cascade)
  cohort         FormationCohort? @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  lessonProgress LessonProgress[]
  certificate    Certificate?
  notes          LessonNote[]
  refundRequests RefundRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, formationId])
  @@index([userId])
  @@index([formationId])
  @@index([cohortId])
  @@index([createdAt])
}

model LessonProgress {
  id           String     @id @default(cuid())
  enrollmentId String
  lessonId     String
  completed    Boolean    @default(false)
  score        Int? // score quiz 0-100
  watchedPct   Float? // pourcentage visionné pour les vidéos
  completedAt  DateTime?
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
}

model LessonNote {
  id           String   @id @default(cuid())
  enrollmentId String
  lessonId     String
  content      String   @db.Text
  timestamp    Int? // secondes dans la vidéo
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, lessonId])
}

model Certificate {
  id             String    @id @default(cuid())
  code           String    @unique
  enrollmentId   String    @unique
  userId         String
  formationId    String
  score          Int       @default(0)
  pdfUrl         String?
  pdfStoragePath String?
  revokedAt      DateTime?
  revokeReason   String?
  issuedAt       DateTime  @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user       User       @relation("UserCertificates", fields: [userId], references: [id], onDelete: Cascade)
  formation  Formation  @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@index([formationId])
}

model FormationReview {
  id           String    @id @default(cuid())
  rating       Int // 1-5
  comment      String    @db.Text
  userId       String
  formationId  String
  enrollmentId String?
  response     String?   @db.Text
  respondedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user      User      @relation("UserFormationReviews", fields: [userId], references: [id], onDelete: Cascade)
  formation Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([userId, formationId])
  @@index([formationId])
  @@index([userId])
}

model CartItem {
  id          String   @id @default(cuid())
  userId      String
  formationId String
  createdAt   DateTime @default(now())

  user      User      @relation("UserCartItems", fields: [userId], references: [id], onDelete: Cascade)
  formation Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([userId, formationId])
  @@index([userId])
}

model PromoCode {
  id           String    @id @default(cuid())
  code         String    @unique
  discountPct  Int // 0-100
  maxUsage     Int? // null = illimité
  usageCount   Int       @default(0)
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  formationIds String[]  @default([]) // vide = tous les cours

  createdAt DateTime @default(now())

  @@index([code])
}

model InstructorWithdrawal {
  id             String    @id @default(cuid())
  instructeurId  String
  shopId          String?
  amount         Float
  method         String // code Moneroo (wave_sn, orange_money_ci...) ou "bank_transfer"
  accountDetails Json   // phone / iban / email / etc. selon la méthode
  status         String    @default("EN_ATTENTE") // EN_ATTENTE, TRAITE, REFUSE
  refusedReason  String?
  processedAt    DateTime?
  // Trace Moneroo : id du payout côté provider + nom du provider
  paymentRef     String?
  paymentProvider String?  // "moneroo" | "manual"
  errorMessage   String?   // message d'erreur Moneroo si echec
  createdAt      DateTime  @default(now())

  instructeur InstructeurProfile @relation("InstructeurWithdrawals", fields: [instructeurId], references: [id], onDelete: Cascade)

  @@index([instructeurId])
  @@index([status])
  @@index([paymentRef])
}

/// Retraits de la commission plateforme Novakou (5% de chaque vente).
/// Réservé aux users avec role=ADMIN — les comptes admin membres ne peuvent PAS
/// retirer (implémenté via check isMainAdmin côté API).
model PlatformPayout {
  id             String    @id @default(cuid())
  adminUserId    String    // userId de l'admin qui a fait la demande
  amount         Float
  method         String    // "virement" | "mobile_money" | "paypal" | "wise"
  accountDetails Json      // IBAN, email, numéro...
  status         String    @default("EN_ATTENTE") // EN_ATTENTE | TRAITE | REFUSE
  processedAt    DateTime?
  note           String?
  createdAt      DateTime  @default(now())

  @@index([adminUserId])
  @@index([status])
}

// ── Enums produits numériques & marketing ──

enum DigitalProductType {
  EBOOK
  PDF
  TEMPLATE
  LICENCE
  AUDIO
  VIDEO
  AUTRE
}

enum DigitalProductStatus {
  BROUILLON
  EN_ATTENTE
  ACTIF
  ARCHIVE
  REFUSE
}

enum PixelType {
  FACEBOOK
  GOOGLE
  TIKTOK
}

enum MarketingEventType {
  PAGE_VIEW
  ADD_TO_CART
  CHECKOUT_STARTED
  PURCHASE_COMPLETED
  PAYMENT_FAILED
  CART_ABANDONED
}

enum AbandonedCartStatus {
  DETECTE
  RELANCE_1
  RELANCE_2
  RELANCE_3
  CONVERTI
  TERMINE
  DESABONNE
}

// ── Produits Numériques ──

model DigitalProduct {
  id   String @id @default(cuid())
  slug String @unique

  // Contenu (langue unique)
  title             String
  description       String? @db.Text
  descriptionFormat String  @default("text") // "text" | "tiptap"
  locale            String  @default("fr")

  // Type de produit
  productType DigitalProductType @default(EBOOK)

  // Médias
  banner          String? // URL image bannière/couverture
  fileUrl         String? // URL Supabase Storage
  fileStoragePath String? // chemin dans le bucket
  fileSize        Int? // bytes
  fileMimeType    String?

  // Aperçu
  previewEnabled   Boolean @default(false)
  previewPages     Int     @default(5) // nombre de pages pour l'aperçu PDF
  watermarkEnabled Boolean @default(true)

  // Prix
  price         Float   @default(0)
  originalPrice Float?
  isFree        Boolean @default(false)

  // Stock limité
  maxBuyers     Int? // null = illimité
  currentBuyers Int  @default(0)

  // Stats
  rating       Float @default(0)
  reviewsCount Int   @default(0)
  salesCount   Int   @default(0)
  viewsCount   Int   @default(0)

  // Tags
  tags String[] @default([])

  // Statut
  status       DigitalProductStatus @default(BROUILLON)
  refuseReason String?

  // Visibilité — true = exclusivement dans la boutique du vendeur, pas dans /explorer
  hiddenFromMarketplace Boolean @default(false)

  // Multi-shop : à quelle boutique du vendeur appartient ce produit
  shopId String?
  shop   VendorShop? @relation("ShopProducts", fields: [shopId], references: [id], onDelete: SetNull)

  // Relations
  instructeurId   String
  categoryId      String
  instructeur     InstructeurProfile       @relation("InstructeurProducts", fields: [instructeurId], references: [id], onDelete: Cascade)
  category        FormationCategory        @relation("CategoryProducts", fields: [categoryId], references: [id])
  purchases       DigitalProductPurchase[]
  reviews         DigitalProductReview[]
  flashPromotions FlashPromotion[]         @relation("ProductFlashPromos")
  marketingEvents MarketingEvent[]         @relation("ProductMarketingEvents")
  bundleItems     ProductBundleItem[]
  orderBumpsAsBump OrderBump[]             @relation("BumpProduct")
  inquiries       ProductInquiry[]
  checkoutAttempts CheckoutAttempt[]       @relation("ProductCheckoutAttempts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([instructeurId])
  @@index([categoryId])
  @@index([status])
  @@index([productType])
  @@index([rating])
  @@index([createdAt])
  @@index([salesCount])
  @@index([price])
}

model DigitalProductPurchase {
  id              String  @id @default(cuid())
  userId          String
  productId       String
  paidAmount      Float   @default(0)
  stripeSessionId String?
  licenseKey      String? // clé de licence unique si type LICENCE
  downloadCount   Int     @default(0)
  maxDownloads    Int     @default(5)

  user    User           @relation("UserProductPurchases", fields: [userId], references: [id], onDelete: Cascade)
  product DigitalProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([stripeSessionId])
}

model DigitalProductReview {
  id          String    @id @default(cuid())
  rating      Int // 1-5
  comment     String    @db.Text
  userId      String
  productId   String
  response    String?   @db.Text // réponse de l'instructeur
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User           @relation("UserProductReviews", fields: [userId], references: [id], onDelete: Cascade)
  product DigitalProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

// ── Promotions Flash ──

model FlashPromotion {
  id               String   @id @default(cuid())
  formationId      String?
  digitalProductId String?
  discountPct      Int // 1-90
  startsAt         DateTime
  endsAt           DateTime
  maxUsage         Int? // null = illimité
  usageCount       Int      @default(0)
  isActive         Boolean  @default(true)

  formation      Formation?      @relation("FormationFlashPromos", fields: [formationId], references: [id], onDelete: Cascade)
  digitalProduct DigitalProduct? @relation("ProductFlashPromos", fields: [digitalProductId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([formationId])
  @@index([digitalProductId])
  @@index([isActive, endsAt])
}

// ── Paniers Abandonnés ──

model AbandonedCart {
  id            String              @id @default(cuid())
  // userId nullable : guest carts n'ont pas encore de compte
  userId        String?
  // email capturé (soit via session connectée, soit saisi à la sortie du checkout)
  email         String?
  // Ce que le user comptait acheter (formation IDs ou product IDs)
  cartItemIds   String[]            @default([])
  detectedAt    DateTime            @default(now())
  emailSequence Int                 @default(0) // 0=aucun envoyé, 1=1h, 2=24h, 3=7j
  lastEmailAt   DateTime?
  status        AbandonedCartStatus @default(DETECTE)

  user User? @relation("UserAbandonedCarts", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([detectedAt])
}

// ── Checkout Attempts (abandons + paiements echoues) ───────────
// Trace chaque tentative d'achat : si le visiteur a demarre un paiement
// mais n'est pas alle au bout (abandonne) OU si le paiement a echoue
// cote provider, on l'enregistre avec ses coordonnees. Le vendeur peut
// ensuite relancer par email/WhatsApp. Novakou envoie automatiquement
// 2 rappels par email (30 min puis 24h apres).

enum CheckoutAttemptStatus {
  STARTED     // checkout ouvert, paiement pas lance
  ABANDONED   // visiteur a quitte sans payer (timeout 30min)
  FAILED      // paiement initie mais a echoue (carte refusee, fonds insuffisants, etc.)
  COMPLETED   // achat reussi — on garde pour stats
  RECOVERED   // apres un abandon/echec, le visiteur est revenu et a termine
}

model CheckoutAttempt {
  id            String @id @default(cuid())

  // Visiteur
  userId        String?  // si connecte
  visitorEmail  String?
  visitorName   String?
  visitorPhone  String?  // format E.164 (+221 77...) pour WhatsApp

  // Contexte vendeur
  instructeurId String?
  shopId        String?
  formationId   String?
  productId     String?
  funnelId      String?

  // Paiement
  amount        Float
  currency      String   @default("XOF")
  paymentMethod String?  // "card", "orange_sn", "wave_sn", "mtn_ci", etc.

  // Etat
  status        CheckoutAttemptStatus @default(STARTED)
  failureReason String?  @db.Text    // message lisible : "Carte refusee par la banque"
  failureCode   String?               // code technique du provider
  providerRef   String?               // Moneroo transaction id

  // Relances (geree par cron)
  reminder1SentAt DateTime?  // email 30min apres
  reminder2SentAt DateTime?  // email 24h apres
  vendorContactedAt DateTime? // si le vendeur a relance manuellement
  recoveredAt      DateTime? // si le visiteur a termine l'achat ensuite

  metadata Json? // divers (user agent, utm, etc.)

  user        User?               @relation("UserCheckoutAttempts", fields: [userId], references: [id], onDelete: SetNull)
  instructeur InstructeurProfile? @relation("InstructeurCheckoutAttempts", fields: [instructeurId], references: [id], onDelete: SetNull)
  formation   Formation?          @relation("FormationCheckoutAttempts", fields: [formationId], references: [id], onDelete: SetNull)
  product     DigitalProduct?     @relation("ProductCheckoutAttempts", fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructeurId, status])
  @@index([visitorEmail])
  @@index([status, createdAt])
  @@index([createdAt])
}

// ── Marketing Pixels ──

model MarketingPixel {
  id            String    @id @default(cuid())
  instructeurId String
  shopId          String?
  type          PixelType
  pixelId       String // ID du pixel (ex: "123456789012345" pour Facebook)
  isActive      Boolean   @default(true)

  instructeur InstructeurProfile @relation("InstructeurPixels", fields: [instructeurId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([instructeurId, type])
  @@index([instructeurId])
}

// ── Marketing Events ──

model MarketingEvent {
  id               String             @id @default(cuid())
  type             MarketingEventType
  formationId      String?
  digitalProductId String?
  userId           String?
  metadata         Json?

  formation      Formation?      @relation("FormationMarketingEvents", fields: [formationId], references: [id], onDelete: SetNull)
  digitalProduct DigitalProduct? @relation("ProductMarketingEvents", fields: [digitalProductId], references: [id], onDelete: SetNull)
  user           User?           @relation("UserMarketingEvents", fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([formationId])
  @@index([digitalProductId])
  @@index([userId])
}

// ── Course Discussions ──

model CourseDiscussion {
  id          String  @id @default(cuid())
  formationId String
  userId      String
  title       String
  content     String  @db.Text
  isPinned    Boolean @default(false)
  isResolved  Boolean @default(false)
  status      String  @default("active") // active, locked, deleted
  reportCount Int     @default(0)

  formation Formation               @relation(fields: [formationId], references: [id], onDelete: Cascade)
  user      User                    @relation("UserDiscussions", fields: [userId], references: [id], onDelete: Cascade)
  replies   CourseDiscussionReply[]
  reports   DiscussionReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([formationId, createdAt])
  @@index([userId])
  @@index([reportCount])
  @@index([status])
}

model CourseDiscussionReply {
  id           String  @id @default(cuid())
  discussionId String
  userId       String
  content      String  @db.Text
  isInstructor Boolean @default(false)
  status       String  @default("active") // active, deleted
  reportCount  Int     @default(0)

  discussion CourseDiscussion   @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User               @relation("UserDiscussionReplies", fields: [userId], references: [id], onDelete: Cascade)
  reports    DiscussionReport[] @relation("ReplyReports")

  createdAt DateTime @default(now())

  @@index([discussionId, createdAt])
  @@index([userId])
}

// ── Cohortes (Formations groupées) ──

model FormationCohort {
  id          String @id @default(cuid())
  formationId String

  // Contenu (langue unique)
  title       String
  description String? @db.Text

  // Dates
  startDate          DateTime
  endDate            DateTime
  enrollmentDeadline DateTime
  durationDays       Int

  // Capacité
  maxParticipants Int
  currentCount    Int @default(0)

  // Prix
  price         Float
  originalPrice Float?

  // Statut
  status CohortStatus @default(OUVERT)

  // Programme semaine par semaine (JSON)
  schedule Json?

  // Relations
  formation   Formation       @relation(fields: [formationId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  messages    CohortMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([formationId])
  @@index([status])
  @@index([startDate])
  @@index([enrollmentDeadline])
}

model CohortMessage {
  id             String  @id @default(cuid())
  cohortId       String
  userId         String
  content        String  @db.Text
  isInstructor   Boolean @default(false)
  isPinned       Boolean @default(false)
  attachmentUrl  String?
  attachmentName String?

  cohort FormationCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User            @relation("UserCohortMessages", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cohortId, createdAt])
  @@index([userId])
  @@index([cohortId, isPinned])
}

// ══════════════════════════════════════════════════════════════
// MARKETING SYSTEM — Affiliate, Discounts, Email Automation,
// Funnels, Popups, Campaigns, Analytics, Automation Engine
// ══════════════════════════════════════════════════════════════

// ── Enums ─────────────────────────────────────────────────────

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DiscountScope {
  ALL
  FORMATIONS
  PRODUCTS
  SPECIFIC
}

enum EmailSequenceTrigger {
  PURCHASE
  ENROLLMENT
  ABANDONED_CART
  USER_INACTIVITY
  COURSE_COMPLETION
  SIGNUP
  MANUAL
  TAG_ADDED
}

enum EmailStepType {
  EMAIL
  DELAY
  CONDITION
  TAG_ACTION
}

enum SequenceEnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum FunnelStepType {
  LANDING
  PRODUCT
  CHECKOUT
  UPSELL
  DOWNSELL
  CONFIRMATION
  THANK_YOU
}

enum PopupTrigger {
  EXIT_INTENT
  TIME_DELAY
  SCROLL_PERCENT
  PAGE_VIEW_COUNT
  MANUAL
}

enum PopupType {
  DISCOUNT
  EMAIL_CAPTURE
  ANNOUNCEMENT
  UPSELL
  COUNTDOWN
}

enum AutomationTriggerType {
  PURCHASE
  ENROLLMENT
  CART_ABANDONED
  COURSE_COMPLETED
  LESSON_COMPLETED
  QUIZ_PASSED
  QUIZ_FAILED
  USER_SIGNUP
  USER_INACTIVE
  TAG_ADDED
  TAG_REMOVED
  AFFILIATE_SALE
  FUNNEL_STEP_REACHED
  CUSTOM_EVENT
}

enum AutomationActionType {
  SEND_EMAIL
  ADD_TAG
  REMOVE_TAG
  ENROLL_SEQUENCE
  CANCEL_SEQUENCE
  GRANT_ACCESS
  REVOKE_ACCESS
  SEND_NOTIFICATION
  WEBHOOK
  DELAY
  CONDITION_CHECK
  CREATE_DISCOUNT
  TRIGGER_UPSELL
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

/// Demande de suppression de compte par l'utilisateur.
/// Flow: PENDING_COOLDOWN (72h annulable par user) → AWAITING_REVIEW → APPROVED (compte supprimé) ou REJECTED.
enum AccountDeletionStatus {
  PENDING_COOLDOWN
  AWAITING_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

model AccountDeletionRequest {
  id            String                @id @default(cuid())
  userId        String                @unique
  user          User                  @relation("UserDeletionRequest", fields: [userId], references: [id], onDelete: Cascade)
  reason        String                @db.Text
  status        AccountDeletionStatus @default(PENDING_COOLDOWN)
  requestedAt   DateTime              @default(now())
  cooldownUntil DateTime              // requestedAt + 72h
  reviewedAt    DateTime?
  reviewedBy    String?               // admin user id
  adminNote     String?               @db.Text
  completedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([cooldownUntil])
}

// ── Affiliate System ──────────────────────────────────────────

model AffiliateProgram {
  id              String   @id @default(cuid())
  instructeurId   String
  shopId          String?
  name            String
  description     String?  @db.Text
  commissionPct   Float    @default(20) // default 20%
  cookieDays      Int      @default(30) // tracking cookie duration
  isActive        Boolean  @default(true)
  minPayoutAmount Float    @default(20) // minimum €20 for payout
  autoApprove     Boolean  @default(true) // auto-approve affiliates
  // Scope: which products/courses
  applyToAll      Boolean  @default(true)
  formationIds    String[] @default([])
  productIds      String[] @default([])

  instructeur InstructeurProfile @relation("InstructeurAffiliatePrograms", fields: [instructeurId], references: [id], onDelete: Cascade)
  affiliates  AffiliateProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructeurId])
  @@index([isActive])
}

model AffiliateProfile {
  id               String          @id @default(cuid())
  userId           String          @unique
  programId        String
  affiliateCode    String          @unique // unique code for links
  status           AffiliateStatus @default(PENDING)
  totalClicks      Int             @default(0)
  totalConversions Int             @default(0)
  totalEarned      Float           @default(0)
  pendingEarnings  Float           @default(0)
  paidEarnings     Float           @default(0)
  conversionRate   Float           @default(0)
  paypalEmail      String?
  bankDetails      Json?

  user        User                  @relation("UserAffiliateProfile", fields: [userId], references: [id], onDelete: Cascade)
  program     AffiliateProgram      @relation(fields: [programId], references: [id], onDelete: Cascade)
  clicks      AffiliateClick[]
  commissions AffiliateCommission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([programId])
  @@index([affiliateCode])
  @@index([status])
}

model AffiliateClick {
  id           String  @id @default(cuid())
  affiliateId  String
  visitorId    String? // anonymous visitor ID (cookie)
  userId       String? // if visitor is logged in
  ip           String?
  userAgent    String?
  referer      String?
  landingPage  String?
  converted    Boolean @default(false)
  conversionId String? // link to commission

  affiliate AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  user      User?            @relation("UserAffiliateClicks", fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([affiliateId])
  @@index([visitorId])
  @@index([userId])
  @@index([createdAt])
  @@index([converted])
}

model AffiliateCommission {
  id               String           @id @default(cuid())
  affiliateId      String
  orderId          String? // enrollment or purchase reference
  orderType        String // "formation" or "product"
  orderAmount      Float // total sale amount
  commissionPct    Float // % at time of sale
  commissionAmount Float // calculated amount
  status           CommissionStatus @default(PENDING)
  paidAt           DateTime?
  payoutRef        String? // payout transaction reference

  affiliate AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([affiliateId])
  @@index([status])
  @@index([createdAt])
}

// ── Discount System ───────────────────────────────────────────

model DiscountCode {
  id              String        @id @default(cuid())
  instructeurId   String
  shopId          String?
  code            String        @unique
  discountType    DiscountType  @default(PERCENTAGE)
  discountValue   Float // percentage (0-100) or fixed amount
  scope           DiscountScope @default(ALL)
  formationIds    String[]      @default([])
  productIds      String[]      @default([])
  maxUses         Int? // null = unlimited
  usedCount       Int           @default(0)
  maxUsesPerUser  Int? // null = unlimited
  minOrderAmount  Float? // minimum order value
  expiresAt       DateTime?
  isActive        Boolean       @default(true)

  // Advanced conditions
  // firstOrderOnly : only redeemable if the user has no prior successful purchase.
  // bogoQuantityBuy + bogoQuantityFree : buy N, get M free (requires cart ≥ N+M).
  // tieredRules : JSON array [{ qty: 2, pct: 10 }, { qty: 3, pct: 20 }] — picks the
  //               highest matching tier based on cart item count.
  // triggerContext : "welcome" | "abandoned_cart" | "birthday" | "generic" (for analytics).
  firstOrderOnly   Boolean  @default(false)
  bogoQuantityBuy  Int?
  bogoQuantityFree Int?
  tieredRules      Json?
  triggerContext   String?

  // Tracking
  totalDiscounted Float         @default(0) // total amount discounted
  revenue         Float         @default(0) // total revenue from discounted sales

  instructeur InstructeurProfile @relation("InstructeurDiscountCodes", fields: [instructeurId], references: [id], onDelete: Cascade)
  usages      DiscountUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([instructeurId])
  @@index([isActive])
  @@index([expiresAt])
  @@index([triggerContext])
}

model DiscountUsage {
  id             String @id @default(cuid())
  discountId     String
  userId         String
  orderType      String // "formation" or "product"
  orderId        String
  originalAmount Float
  discountAmount Float
  finalAmount    Float

  discount DiscountCode @relation(fields: [discountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([discountId, userId, orderId])
  @@index([discountId])
  @@index([userId])
}

// ── Email Automation System ───────────────────────────────────

model EmailSequence {
  id             String               @id @default(cuid())
  instructeurId  String
  shopId          String?
  name           String
  description    String?              @db.Text
  trigger        EmailSequenceTrigger
  triggerConfig  Json? // additional trigger config (e.g., days of inactivity)
  isActive       Boolean              @default(false)
  totalEnrolled  Int                  @default(0)
  totalCompleted Int                  @default(0)

  instructeur InstructeurProfile        @relation("InstructeurEmailSequences", fields: [instructeurId], references: [id], onDelete: Cascade)
  steps       EmailSequenceStep[]
  enrollments EmailSequenceEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructeurId])
  @@index([trigger])
  @@index([isActive])
}

model EmailSequenceStep {
  id             String        @id @default(cuid())
  sequenceId     String
  stepOrder      Int
  stepType       EmailStepType @default(EMAIL)
  // For EMAIL type
  subjectFr      String?
  subjectEn      String?
  bodyFr         String?       @db.Text
  bodyEn         String?       @db.Text
  // For DELAY type
  delayMinutes   Int? // delay in minutes (1440 = 1 day)
  // For CONDITION type
  conditionField String? // e.g., "course_progress", "has_purchased"
  conditionOp    String? // "gte", "eq", "contains"
  conditionValue String?
  // For TAG_ACTION type
  tagAction      String? // "add" or "remove"
  tagName        String?

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sequenceId])
  @@index([stepOrder])
}

model EmailSequenceEnrollment {
  id             String                   @id @default(cuid())
  sequenceId     String
  userId         String
  currentStepIdx Int                      @default(0)
  status         SequenceEnrollmentStatus @default(ACTIVE)
  nextStepAt     DateTime? // when to execute next step
  completedAt    DateTime?
  metadata       Json? // user-specific context data

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  user     User          @relation("UserEmailSeqEnrollments", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sequenceId, userId])
  @@index([sequenceId])
  @@index([userId])
  @@index([status, nextStepAt])
}

// ── Sales Funnel System ───────────────────────────────────────

model SalesFunnel {
  id               String  @id @default(cuid())
  instructeurId    String
  shopId          String?
  name             String
  slug             String  @unique
  description      String? @db.Text
  isActive         Boolean @default(false)
  totalViews       Int     @default(0)
  totalConversions Int     @default(0)
  totalRevenue     Float   @default(0)

  // Theme config (shared across steps): { primaryColor, accentColor, font, logoUrl, ... }
  theme Json?

  instructeur InstructeurProfile @relation("InstructeurSalesFunnels", fields: [instructeurId], references: [id], onDelete: Cascade)
  steps       FunnelStep[]
  events      FunnelEvent[]
  abTests     FunnelABTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructeurId])
  @@index([slug])
  @@index([isActive])
}

model FunnelStep {
  id            String         @id @default(cuid())
  funnelId      String
  stepOrder     Int
  stepType      FunnelStepType @default(PRODUCT)
  title         String
  // Product reference
  formationId   String?
  productId     String?
  // Config
  discountPct   Float? // optional discount at this step
  headlineFr    String?
  headlineEn    String?
  descriptionFr String?        @db.Text
  descriptionEn String?        @db.Text
  ctaTextFr     String?
  ctaTextEn     String?
  // Rich block-based content — JSON array of blocks (hero, features, testimonials, countdown, FAQ, etc.)
  blocks        Json?
  // Tracking
  views         Int            @default(0)
  conversions   Int            @default(0)

  funnel SalesFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([funnelId])
  @@index([stepOrder])
}

model FunnelEvent {
  id        String  @id @default(cuid())
  funnelId  String
  stepId    String?
  userId    String?
  visitorId String?
  eventType String // "view", "click", "purchase", "skip"
  metadata  Json?

  funnel SalesFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  user   User?       @relation("UserFunnelEvents", fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([funnelId])
  @@index([stepId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

// ── Smart Popups & Conversion Tools ───────────────────────────

model SmartPopup {
  id               String       @id @default(cuid())
  instructeurId    String
  shopId          String?
  name             String
  popupType        PopupType    @default(DISCOUNT)
  trigger          PopupTrigger @default(TIME_DELAY)
  // Trigger config
  delaySeconds     Int? // for TIME_DELAY
  scrollPercent    Int? // for SCROLL_PERCENT (0-100)
  pageViewCount    Int? // for PAGE_VIEW_COUNT
  // Content
  headlineFr       String?
  headlineEn       String?
  bodyFr           String?      @db.Text
  bodyEn           String?      @db.Text
  ctaTextFr        String?
  ctaTextEn        String?
  imageBanner      String?
  // Discount link
  discountCodeId   String?
  // Email capture
  emailListTag     String? // tag to add when email captured
  // Targeting
  showOnPages      String[]     @default([]) // empty = all pages
  excludePages     String[]     @default([])
  showToNewOnly    Boolean      @default(false)
  maxShowsPerUser  Int          @default(1)
  // State
  isActive         Boolean      @default(false)
  // Stats
  totalImpressions Int          @default(0)
  totalClicks      Int          @default(0)
  totalConversions Int          @default(0)

  instructeur InstructeurProfile @relation("InstructeurSmartPopups", fields: [instructeurId], references: [id], onDelete: Cascade)
  impressions PopupImpression[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructeurId])
  @@index([isActive])
  @@index([popupType])
}

model PopupImpression {
  id        String  @id @default(cuid())
  popupId   String
  userId    String?
  visitorId String?
  action    String // "view", "click", "close", "convert"
  metadata  Json?

  popup SmartPopup @relation(fields: [popupId], references: [id], onDelete: Cascade)
  user  User?      @relation("UserPopupImpressions", fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([popupId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ── Campaign Tracking ─────────────────────────────────────────

model CampaignTracker {
  id               String  @id @default(cuid())
  instructeurId    String
  shopId          String?
  name             String
  slug             String  @unique // used in URLs
  // UTM parameters
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  // Target
  destinationUrl   String
  // Stats
  totalClicks      Int     @default(0)
  totalConversions Int     @default(0)
  totalRevenue     Float   @default(0)
  isActive         Boolean @default(true)

  instructeur InstructeurProfile @relation("InstructeurCampaignTrackers", fields: [instructeurId], references: [id], onDelete: Cascade)
  events      CampaignEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructeurId])
  @@index([slug])
  @@index([isActive])
}

model CampaignEvent {
  id         String  @id @default(cuid())
  campaignId String
  userId     String?
  visitorId  String?
  eventType  String // "click", "conversion", "purchase"
  ip         String?
  userAgent  String?
  referer    String?
  revenue    Float?
  metadata   Json?

  campaign CampaignTracker @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?           @relation("UserCampaignEvents", fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

// ── Automation Engine ─────────────────────────────────────────

model AutomationWorkflow {
  id              String                @id @default(cuid())
  instructeurId   String
  shopId          String?
  name            String
  description     String?               @db.Text
  status          WorkflowStatus        @default(DRAFT)
  // Trigger
  triggerType     AutomationTriggerType
  triggerConfig   Json? // e.g., { "formationId": "xxx", "minProgress": 80 }
  // Actions (ordered list)
  actions         Json // AutomationActionType[] with config
  // Stats
  totalExecutions Int                   @default(0)
  lastExecutedAt  DateTime?
  // Conditions
  conditions      Json? // optional filter conditions

  instructeur InstructeurProfile @relation("InstructeurAutomationWorkflows", fields: [instructeurId], references: [id], onDelete: Cascade)
  logs        AutomationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructeurId])
  @@index([status])
  @@index([triggerType])
}

model AutomationLog {
  id           String  @id @default(cuid())
  workflowId   String
  userId       String? // user that triggered this
  triggerEvent String // what triggered it
  actionsRun   Json // list of actions executed
  success      Boolean @default(true)
  error        String? @db.Text
  executionMs  Int? // execution time

  workflow AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workflowId])
  @@index([createdAt])
  @@index([success])
}

// ── User Tags ─────────────────────────────────────────────────

model UserTag {
  id     String  @id @default(cuid())
  userId String
  tag    String
  source String? // "automation", "manual", "email_sequence"

  user User @relation("UserTags", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tag])
  @@index([userId])
  @@index([tag])
}

// ── Refund Requests ──

model RefundRequest {
  id           String    @id @default(cuid())
  userId       String
  enrollmentId String
  amount       Float
  reason       String    @db.Text
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNote    String?   @db.Text
  resolvedAt   DateTime?
  resolvedBy   String?

  user       User       @relation("UserRefundRequests", fields: [userId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([enrollmentId])
  @@index([status])
  @@index([createdAt])
}

// ── Discussion Reports ──

model DiscussionReport {
  id           String  @id @default(cuid())
  userId       String
  discussionId String?
  replyId      String?
  reason       String // spam, harassment, inappropriate, off-topic

  user       User                   @relation("UserDiscussionReports", fields: [userId], references: [id], onDelete: Cascade)
  discussion CourseDiscussion?      @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  reply      CourseDiscussionReply? @relation("ReplyReports", fields: [replyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, discussionId])
  @@index([discussionId])
  @@index([replyId])
  @@index([createdAt])
}

// ── Formations Config ──

model FormationsConfig {
  id    String  @id @default(cuid())
  key   String  @unique
  value String
  label String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ── Mentor Space ──────────────────────────────────────────────────────────────

model MentorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation("UserMentorProfile", fields: [userId], references: [id], onDelete: Cascade)

  specialty       String   @default("")
  bio             String   @default("") @db.Text
  domain          String?  // Marketing | Dev | Design | Business | ...
  coverImage      String?
  sessionPrice    Float    @default(25000)
  sessionDuration Int      @default(60)   // minutes
  languages       String[] @default([])
  badges          String[] @default([])
  isAvailable     Boolean  @default(true)
  isVerified      Boolean  @default(false)

  // Booking config
  timezone        String   @default("Africa/Abidjan")
  sessionBuffer   Int      @default(15)   // minutes between 2 sessions
  bookingLeadTime Int      @default(60)   // min minutes before slot can be booked

  // Stats (denormalized for display)
  totalSessions Int   @default(0)
  totalStudents Int   @default(0)
  rating        Float @default(0)
  reviewsCount  Int   @default(0)

  // Discovery session (gratuite, 15 min, first-contact)
  discoveryEnabled         Boolean @default(false)
  discoveryDurationMinutes Int     @default(15)

  // Pre-session questionnaire (JSON array of questions shown when booking)
  // Format: [{ id, label, type: "text" | "choice", required, options? }]
  preSessionQuestions Json?

  // Note: les mentors n'ont PAS de boutique custom (réservé aux vendeurs).

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings           MentorBooking[]
  availabilities     MentorAvailability[]
  availabilitySlots  MentorAvailabilitySlot[]
  sessionPacks       MentorSessionPack[]
  studentNotes       MentorStudentNote[]

  @@index([userId])
  @@index([domain])
  @@index([isAvailable])
}

model MentorAvailability {
  id        String   @id @default(cuid())
  mentorId  String
  mentor    MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0=Sunday, 1=Monday, ..., 6=Saturday
  startMin  Int      // minutes from midnight (0–1439)
  endMin    Int      // minutes from midnight (must be > startMin)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mentorId])
  @@index([dayOfWeek])
}

// Date-based availability (specific date + time range), takes priority over weekly recurrence
model MentorAvailabilitySlot {
  id        String        @id @default(cuid())
  mentorId  String
  mentor    MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  date      DateTime      // Specific date (set to local midnight)
  startMin  Int           // Minutes from midnight (0..1439)
  endMin    Int           // Minutes from midnight (must be > startMin)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([mentorId])
  @@index([date])
  @@index([mentorId, date])
}

model MentorBooking {
  id              String        @id @default(cuid())
  mentorId        String
  mentor          MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  studentId       String
  student         User          @relation("UserMentorBookings", fields: [studentId], references: [id], onDelete: Cascade)

  status          MentorBookingStatus @default(PAYMENT_PENDING)
  scheduledAt     DateTime
  durationMinutes Int              @default(60)
  paidAmount      Float            @default(0)
  sessionNotes    String?          @db.Text
  studentGoals    String?          @db.Text   // What student wrote when booking
  meetingLink     String?
  meetingRoomId   String?                    // Jitsi room id auto-generated
  stripeSessionId String?

  // ── ESCROW ───────────────────────────────────────────────────────
  escrowStatus      MentorEscrowStatus @default(NONE)   // NONE | HELD | RELEASED | REFUNDED | DISPUTED
  paymentRef        String?       // Moneroo transaction id / internalRef
  paymentProvider   String?       // "moneroo" | "mock"
  paidAt            DateTime?     // When the learner paid
  escrowReleasedAt  DateTime?     // When funds were released to mentor

  // ── ANNULATION / DISPUTE ─────────────────────────────────────────
  cancellationReason   String?  @db.Text    // Required when status = CANCELLATION_REQUESTED_*
  cancelledBy          String?              // "student" | "mentor"
  cancelRequestedAt    DateTime?            // When cancellation was requested
  adminDecisionAt      DateTime?            // When admin decided on the dispute
  adminDecisionBy      String?              // Admin userId who decided
  adminDecisionOutcome String?              // "refund_student" | "release_to_mentor" | "split_50_50"
  adminDecisionNote    String?  @db.Text    // Admin explanation shown to both parties

  // Notifications tracking
  reminder24hSentAt   DateTime?
  reminder1hSentAt    DateTime?
  reviewRequestSentAt DateTime?

  // Post-session
  studentRating  Int?     // 1-5
  studentReview  String?  @db.Text
  mentorFeedback String?  @db.Text

  // ── Contrôle de présence (base pour dispute no-show) ──
  studentAttended    Boolean?   // L'apprenant confirme avoir participé
  mentorAttended     Boolean?   // Le mentor confirme avoir participé
  studentAttendedAt  DateTime?
  mentorAttendedAt   DateTime?

  completedAt DateTime?  // Set when status transitions to COMPLETED — used for 24h escrow hold

  // ── Pack consumption (when booking was paid via a MentorSessionPackPurchase) ──
  packPurchaseId String?
  packPurchase   MentorSessionPackPurchase? @relation(fields: [packPurchaseId], references: [id])
  reminders      MentorBookingReminder[]

  // ── Pre-session questionnaire answers + discovery flag ──
  preSessionAnswers Json?
  isDiscovery       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mentorId])
  @@index([studentId])
  @@index([status])
  @@index([scheduledAt])
  @@index([escrowStatus])
  @@index([packPurchaseId])
}

enum MentorBookingStatus {
  PAYMENT_PENDING                // Paiement Moneroo en cours (pas encore confirmé)
  PENDING                        // Payé, en attente de confirmation mentor
  CONFIRMED                      // Mentor a confirmé, session à venir
  CANCELLATION_REQUESTED_STUDENT // Apprenant a annulé avec motif, en attente admin
  CANCELLATION_REQUESTED_MENTOR  // Mentor a annulé avec motif, en attente admin
  CANCELLED                      // Annulation validée (remboursement ou libération selon admin)
  COMPLETED                      // Séance terminée, en attente de libération escrow (24h)
  RELEASED                       // Fonds libérés vers le mentor
  NO_SHOW                        // Mentor ou apprenant ne s'est pas présenté
}

enum MentorEscrowStatus {
  NONE       // Aucun paiement
  HELD       // Fonds bloqués par la plateforme
  RELEASED   // Fonds libérés vers le mentor
  REFUNDED   // Fonds remboursés à l'apprenant
  DISPUTED   // Annulation en attente de décision admin
}

// ── Platform Revenue (commission tracking) ───────────────────────────────────

model PlatformRevenue {
  id              String   @id @default(cuid())
  orderId         String   // enrollment id, product purchase id, or mentor booking id
  orderType       String   // "formation" | "product" | "mentor"
  grossAmount     Float    // total paid by customer
  commissionRate  Float    // % taken (e.g. 0.05 for 5%)
  commissionAmount Float   // platform's share (grossAmount * commissionRate)
  vendorAmount    Float    // vendor's net share (grossAmount - commissionAmount - affiliateAmount)
  affiliateId     String?  // if sale came via affiliate
  affiliateAmount Float    @default(0)
  paymentRef      String?  // Moneroo / Stripe / etc. reference
  currency        String   @default("XOF")

  // Multi-shop : qui touche la part vendeur + dans quelle boutique la vente a eu lieu
  instructeurId   String?
  shopId          String?

  createdAt DateTime @default(now())

  @@index([orderType])
  @@index([createdAt])
  @@index([affiliateId])
  @@index([instructeurId])
  @@index([shopId])
}

// ── Vendor Integrations (Brevo, Make, Zapier, n8n, ConvertKit, Systeme.io) ──

model VendorIntegration {
  id            String             @id @default(cuid())
  instructeurId String
  shopId          String?
  instructeur   InstructeurProfile @relation("InstructeurIntegrations", fields: [instructeurId], references: [id], onDelete: Cascade)
  provider      String             // "brevo" | "make" | "zapier" | "n8n" | "convertkit" | "systemeio"
  connected     Boolean            @default(false)
  apiKey        String?            @db.Text  // MVP: stocké en clair, chiffrer en V2 (AES)
  webhookUrl    String?            @db.Text  // pour Make / Zapier / n8n
  config        Json?                         // provider-specific settings
  lastSyncAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([instructeurId, provider])
  @@index([instructeurId])
}

// ── Vendor Webhooks (événements sortants de la boutique) ──

model VendorWebhook {
  id            String             @id @default(cuid())
  instructeurId String
  shopId          String?
  instructeur   InstructeurProfile @relation("InstructeurWebhooks", fields: [instructeurId], references: [id], onDelete: Cascade)
  url           String             @db.Text
  events        String[]           @default([]) // e.g. ["order.created", "order.paid", "refund.issued"]
  secret        String?                          // optional HMAC secret for signature
  isActive      Boolean            @default(true)
  lastFiredAt   DateTime?
  failureCount  Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([instructeurId])
  @@index([isActive])
}

// ── Vendor API Keys (pour API publique Novakou) ──

model VendorApiKey {
  id            String             @id @default(cuid())
  instructeurId String
  shopId          String?
  instructeur   InstructeurProfile @relation("InstructeurApiKeys", fields: [instructeurId], references: [id], onDelete: Cascade)
  name          String              // ex: "Prod server", "Staging integration"
  keyPrefix     String              // 8 premiers char visibles (ex: "nk_live_ab12")
  keyHash       String              // SHA-256 hash de la clé complète
  scopes        String[]            @default([]) // "read:products", "write:orders", "admin"
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  revokedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([instructeurId])
  @@index([keyPrefix])
  @@index([keyHash])
}

// ─────────────────────────────────────────────────────────────────────────────
// TRACKING & ANALYTICS (persisted to DB, replaces the dev JSON store)
// ─────────────────────────────────────────────────────────────────────────────

model TrackingEventLog {
  id          String   @id @default(cuid())
  eventId     String   @unique // client-generated, used for dedup
  type        String   // matches TrackingEventType
  userId      String?
  sessionId   String
  path        String
  entityType  String?
  entityId    String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  deviceType  String   // mobile | tablet | desktop
  country     String?  // ISO-3166 alpha-2
  userAgent   String?
  metadata    Json?
  isBot       Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([sessionId])
  @@index([userId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([path, createdAt])
  @@index([createdAt])
}

model TrackingSessionLog {
  id            String    @id // the sessionId from client
  userId        String?
  startedAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())
  endedAt       DateTime?
  pageViews     Int       @default(0)
  entryPath     String
  exitPath      String?
  deviceType    String    // mobile | tablet | desktop
  referrer      String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  country       String?
  userAgent     String?
  isBot         Boolean   @default(false)

  @@index([userId, startedAt])
  @@index([startedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// MENTOR — Packs de sessions (3/5/10 à prix dégressif)
// ─────────────────────────────────────────────────────────────────────────────

model MentorSessionPack {
  id            String   @id @default(cuid())
  mentorId      String   // MentorProfile.id
  title         String   // ex. "Pack Transformation 5 séances"
  sessionsCount Int      // nombre de séances incluses
  priceXof      Int      // prix total en FCFA
  sessionDurationMinutes Int @default(60)
  description   String?
  isActive      Boolean  @default(true)
  validityDays  Int      @default(180) // 6 mois par défaut
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mentor        MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  purchases     MentorSessionPackPurchase[]

  @@index([mentorId, isActive])
}

model MentorSessionPackPurchase {
  id               String   @id @default(cuid())
  packId           String
  userId           String   // apprenant
  paidAmount       Int      // FCFA
  sessionsTotal    Int      // copie du pack au moment de l'achat
  sessionsConsumed Int      @default(0)
  expiresAt        DateTime
  refundedAt       DateTime?
  createdAt        DateTime @default(now())

  pack             MentorSessionPack @relation(fields: [packId], references: [id])
  bookings         MentorBooking[]

  @@index([userId, expiresAt])
  @@index([packId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MENTOR — Notes privées sur l'apprenant (CRM léger)
// ─────────────────────────────────────────────────────────────────────────────

model MentorStudentNote {
  id         String   @id @default(cuid())
  mentorId   String   // MentorProfile.id
  studentId  String   // User.id
  content    String   // markdown / texte libre
  tags       String[] // ex. ["objectif", "blocage", "next-step"]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mentor     MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId, studentId, updatedAt])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MENTOR — Rappels de séance (auto-dispatchés par /api/cron/mentor-reminders)
// ─────────────────────────────────────────────────────────────────────────────

model MentorBookingReminder {
  id         String   @id @default(cuid())
  bookingId  String
  kind       String   // "H-24" | "H-15m"
  sentAt     DateTime @default(now())

  booking    MentorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, kind])
  @@index([bookingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// VENDEUR — Bundles produits (pack de N formations/produits à prix réduit)
// ─────────────────────────────────────────────────────────────────────────────

model ProductBundle {
  id            String   @id @default(cuid())
  instructeurId String
  shopId        String?
  slug          String   @unique
  title         String
  description   String?
  thumbnail     String?
  priceXof      Int      // prix total du bundle
  originalPriceXof Int?  // somme des prix individuels (affichage "économie")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  instructeur   InstructeurProfile @relation(fields: [instructeurId], references: [id], onDelete: Cascade)
  shop          VendorShop?        @relation(fields: [shopId], references: [id], onDelete: SetNull)
  items         ProductBundleItem[]
  purchases     ProductBundlePurchase[]

  @@index([instructeurId, isActive])
  @@index([shopId])
}

model ProductBundleItem {
  id          String   @id @default(cuid())
  bundleId    String
  itemKind    String   // "formation" | "digital"
  formationId String?
  productId   String?
  order       Int      @default(0)

  bundle      ProductBundle    @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  formation   Formation?       @relation(fields: [formationId], references: [id])
  product     DigitalProduct?  @relation(fields: [productId], references: [id])

  @@index([bundleId])
}

model ProductBundlePurchase {
  id         String   @id @default(cuid())
  bundleId   String
  userId     String
  paidAmount Int
  createdAt  DateTime @default(now())

  bundle     ProductBundle @relation(fields: [bundleId], references: [id])

  @@index([bundleId, createdAt])
  @@index([userId])
}

// (AbandonedCart model already defined above at line ~1526)

// ─────────────────────────────────────────────────────────────────────────────
// FORMATION — Quiz & attempts (basic multi-choice, auto-graded)
// ─────────────────────────────────────────────────────────────────────────────

model FormationQuiz {
  id          String   @id @default(cuid())
  formationId String   @unique
  title       String
  description String?
  passPct     Int      @default(70) // minimum % for certification
  // Questions as JSON : [{ id, question, choices: [{label, correct}], explanation? }]
  questions   Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)
  attempts    QuizAttempt[]

  @@index([formationId])
}

model QuizAttempt {
  id         String   @id @default(cuid())
  quizId     String
  userId     String
  scorePct   Int      // 0-100
  passed     Boolean  @default(false)
  // Answers : [{ questionId, choiceIndex }]
  answers    Json
  createdAt  DateTime @default(now())

  quiz       FormationQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, userId, createdAt])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// APPRENANT — Streaks & badges (gamification)
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// MENTOR — Abonnements mensuels (X€/mois = Y sessions récurrentes)
// ─────────────────────────────────────────────────────────────────────────────

model MentorSubscriptionPlan {
  id                    String   @id @default(cuid())
  mentorId              String
  title                 String   // "Coaching mensuel — 4 séances"
  sessionsPerMonth      Int      // ex. 4
  priceXofPerMonth      Int      // ex. 150000
  sessionDurationMinutes Int     @default(60)
  description           String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subscriptions         MentorSubscription[]

  @@index([mentorId, isActive])
}

model MentorSubscription {
  id               String   @id @default(cuid())
  planId           String
  userId           String
  status           String   @default("ACTIVE") // "ACTIVE" | "PAUSED" | "CANCELLED"
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  sessionsUsedThisPeriod Int    @default(0)
  cancelledAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  plan             MentorSubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([planId])
}

// ─────────────────────────────────────────────────────────────────────────────
// UTILISATEUR — Méthodes de paiement sauvegardées (1-click checkout)
// ─────────────────────────────────────────────────────────────────────────────

model SavedPaymentMethod {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // "moneroo" | "stripe"
  token        String   // Stored provider token (NEVER raw card/phone)
  brand        String?  // "visa" | "mastercard" | "orange" | "wave" | "mtn"
  last4        String?  // displayable tail (e.g. "4242" or "**78")
  expMonth     Int?
  expYear      Int?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, isDefault])
}

model LearnerStreak {
  id             String   @id @default(cuid())
  userId         String   @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActivityAt DateTime?
  totalMinutes   Int      @default(0) // total study time in minutes (lifetime)
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model LearnerBadge {
  id          String   @id @default(cuid())
  userId      String
  code        String   // "FIRST_LESSON" | "WEEK_STREAK" | "10_LESSONS" | ...
  title       String
  description String
  icon        String   // material-symbol name
  unlockedAt  DateTime @default(now())

  @@unique([userId, code])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MENTOR — Bibliothèque de ressources (PDF, vidéos, liens) partageable après séance
// ─────────────────────────────────────────────────────────────────────────────

model MentorResource {
  id          String   @id @default(cuid())
  mentorId    String   // MentorProfile.id
  title       String
  description String?
  kind        String   // "pdf" | "video" | "link" | "audio" | "other"
  url         String   // Cloudinary / Supabase / external
  fileSize    Int?     // bytes (null for links)
  tags        String[] @default([])
  isPublic    Boolean  @default(false) // visible sur le profil public
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mentorId, createdAt])
  @@index([mentorId, isPublic])
}

// ─────────────────────────────────────────────────────────────────────────────
// MENTOR — Partages de ressources liées à un booking spécifique
// ─────────────────────────────────────────────────────────────────────────────

model MentorResourceShare {
  id         String   @id @default(cuid())
  resourceId String
  bookingId  String?
  studentId  String
  sharedAt   DateTime @default(now())
  viewedAt   DateTime?

  @@index([studentId, sharedAt])
  @@index([bookingId])
  @@index([resourceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ADMIN — Campagnes email broadcast (newsletter interne, annonces, conseils)
// ─────────────────────────────────────────────────────────────────────────────

model AdminCampaign {
  id             String    @id @default(cuid())
  subject        String    // objet du mail (max 200 char)
  htmlBody       String    @db.Text // contenu HTML (éditeur riche)
  segment        String    // "all" | "vendors" | "mentors" | "learners"
  segmentFilter  Json?     // pour segments custom (V2)
  status         String    @default("draft") // draft | sending | sent | failed
  sentAt         DateTime?
  recipientCount Int       @default(0)
  openedCount    Int       @default(0)
  clickedCount   Int       @default(0)
  failedCount    Int       @default(0)
  createdBy      String    // userId de l'admin qui a créé
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  recipients AdminCampaignRecipient[]

  @@index([status])
  @@index([createdAt])
  @@index([createdBy])
}

model AdminCampaignRecipient {
  id         String    @id @default(cuid())
  campaignId String
  userId     String
  email      String
  resendId   String?   // ID Resend pour tracking
  status     String    @default("pending") // pending | sent | failed | bounced
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?

  campaign AdminCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([userId])
  @@index([status])
}

// ═════════════════════════════════════════════════════════════════════════════
// ORDER BUMPS — offres additionnelles au checkout (boost du panier moyen)
// ═════════════════════════════════════════════════════════════════════════════
// Un Order Bump est un produit proposé via checkbox au moment du checkout,
// AVANT le paiement. Exemple : l'acheteur commande une formation à 25 000 F,
// on lui propose « Ajoutez le pack ressources bonus + 2 900 F » → case cochée,
// total = 27 900 F, une seule transaction, les 2 produits sont délivrés.
//
// Différent des Upsells (qui apparaissent APRÈS paiement) : les bumps boostent
// la transaction initiale sans re-demander les coordonnées de paiement.
//
// - bumpFormationId OU bumpProductId (exactement un des deux)
// - targetFormationIds + targetProductIds : sur quels produits ce bump apparaît
// - appliesToAll : shortcut pour afficher ce bump sur TOUT le catalog du vendeur

model OrderBump {
  id            String  @id @default(cuid())
  instructeurId String
  shopId        String?

  // Contenu affiché à l'acheteur
  title       String  // "Pack ressources bonus"
  description String  @db.Text // "Modèles Excel + 50 templates prêts à l'emploi"
  imageUrl    String?

  // Le produit proposé en bump (un seul des deux)
  bumpFormationId String?
  bumpProductId   String?

  // Pricing
  price         Float // Prix du bump (souvent discounté)
  originalPrice Float? // Prix normal pour affichage barré

  // Ciblage : sur quel(s) produit(s) de la source ce bump s'affiche
  appliesToAll       Boolean  @default(false) // Si true, ignore les listes ci-dessous
  targetFormationIds String[] @default([])
  targetProductIds   String[] @default([])

  // Stats (mises à jour par fulfillment)
  viewsCount    Int @default(0)
  acceptedCount Int @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructeur   InstructeurProfile @relation("InstructeurOrderBumps", fields: [instructeurId], references: [id], onDelete: Cascade)
  bumpFormation Formation?         @relation("BumpFormation", fields: [bumpFormationId], references: [id], onDelete: SetNull)
  bumpProduct   DigitalProduct?    @relation("BumpProduct", fields: [bumpProductId], references: [id], onDelete: SetNull)

  @@index([instructeurId, isActive])
  @@index([shopId])
  @@index([bumpFormationId])
  @@index([bumpProductId])
}

// ═════════════════════════════════════════════════════════════════════════════
// MEMBERSHIPS — abonnements recurrents aux formations/contenu
// ═════════════════════════════════════════════════════════════════════════════
// Un vendeur cree un SubscriptionPlan (tarif mensuel/annuel, liste de
// formations/produits inclus). Les acheteurs s'abonnent -> paiement initial
// via Moneroo -> Subscription cree avec currentPeriodEnd = now + interval.
// Un cron quotidien verifie les abonnements qui expirent, envoie un email
// de renouvellement avec lien de paiement. Si l'acheteur ne paie pas dans
// les 3 jours, status passe a PAST_DUE puis EXPIRED.

model SubscriptionPlan {
  id            String  @id @default(cuid())
  instructeurId String
  shopId        String?

  // Contenu marketing
  name        String  // "Membre Elite", "Mentorat Mensuel", etc.
  description String  @db.Text
  imageUrl    String?

  // Pricing
  price    Float   // Prix par periode (ex: 15000 pour 15k FCFA/mois)
  currency String  @default("XOF")
  interval String  // "monthly" | "yearly" (simple pour MVP)

  // Acces offert
  linkedFormationIds String[] @default([]) // formations debloqees
  linkedProductIds   String[] @default([])

  // Features optionnelles
  trialDays   Int? // 0 ou null = pas d'essai gratuit
  maxMembers  Int? // optionnel, cap le nb d'abonnes actifs

  // Stats
  activeCount Int @default(0) // maintenu par cron/webhook
  totalEarned Float @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructeur  InstructeurProfile @relation("InstructeurPlans", fields: [instructeurId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([instructeurId, isActive])
  @@index([shopId])
}

model Subscription {
  id     String @id @default(cuid())
  userId String
  planId String

  // Cycle
  status   String   // "trialing" | "active" | "past_due" | "cancelled" | "expired"
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  cancelledAt        DateTime?

  // Historique
  lastPaymentAt  DateTime?
  nextInvoiceAt  DateTime?
  totalPaid      Float    @default(0)
  renewalCount   Int      @default(0)

  // Paiement
  paymentMethod String? // snapshot de la methode utilisee (ex: "mtn_bj")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User             @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  plan    SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  invoices SubscriptionInvoice[]

  @@unique([userId, planId]) // un user = 1 sub active par plan
  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
}

model SubscriptionInvoice {
  id             String @id @default(cuid())
  subscriptionId String
  userId         String

  amount    Float
  currency  String @default("XOF")
  status    String // "pending" | "paid" | "failed"

  periodStart DateTime
  periodEnd   DateTime

  paymentRef      String? // Moneroo payout/payment ID
  paymentProvider String? // "moneroo"
  paidAt          DateTime?
  failedAt        DateTime?
  errorMessage    String?

  createdAt DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([userId])
  @@index([status])
}

// ═════════════════════════════════════════════════════════════════════════════
// PRODUCT INQUIRIES — questions pre-achat (alternative simple au live chat)
// ═════════════════════════════════════════════════════════════════════════════
// Visiteur/acheteur peut poser une question sur une page produit sans s'inscrire.
// Le vendeur recoit un email + voit l'inquiry dans son dashboard. Il repond via
// email direct (reply-to pointe sur l'email du visiteur) ou via l'UI.

model ProductInquiry {
  id            String  @id @default(cuid())
  instructeurId String
  shopId        String?

  // A quoi se rapporte la question
  formationId String?
  productId   String?

  // Visiteur (peut etre guest, pas d'auth requise)
  visitorUserId String? // si connecté
  visitorName   String
  visitorEmail  String
  visitorPhone  String?

  // Contenu
  subject String
  message String  @db.Text

  // Etat
  status     String    @default("pending") // pending | replied | closed
  repliedAt  DateTime?
  reply      String?   @db.Text // La reponse courte enregistree (optionnel)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructeur InstructeurProfile @relation("InstructeurInquiries", fields: [instructeurId], references: [id], onDelete: Cascade)
  formation   Formation?         @relation(fields: [formationId], references: [id], onDelete: SetNull)
  product     DigitalProduct?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([instructeurId, status])
  @@index([formationId])
  @@index([productId])
  @@index([visitorEmail])
  @@index([createdAt])
}

// ═════════════════════════════════════════════════════════════════════════════
// A/B TESTING FUNNELS (Phase 2 #8)
// ═════════════════════════════════════════════════════════════════════════════
// Un vendeur cree une experience A/B sur son funnel : 2 variantes de landing
// page, Novakou route 50/50 selon un hash du visitor_id (cookie persistant).
// Tracking des impressions + conversions par variante, tableau de bord simple.

model FunnelABTest {
  id       String @id @default(cuid())
  funnelId String

  name       String  // "Hero v2 vs original"
  variantA   String  // nom de la variante A (ex: "Original")
  variantB   String  // nom de la variante B (ex: "Avec badge urgence")
  blocksA    Json    // snapshot blocks de la landing variante A
  blocksB    Json    // snapshot blocks de la landing variante B

  isActive  Boolean @default(true)
  winner    String? // "A" | "B" | null (auto-determined ou admin)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  funnel SalesFunnel          @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  events FunnelABTestEvent[]

  @@index([funnelId, isActive])
}

model FunnelABTestEvent {
  id        String   @id @default(cuid())
  testId    String
  variant   String   // "A" ou "B"
  eventType String   // "view" | "conversion"
  visitorId String   // cookie-based id stable
  orderValue Float?  // si conversion, montant de l'achat
  createdAt DateTime @default(now())

  test FunnelABTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId, variant, eventType])
  @@index([visitorId])
}
