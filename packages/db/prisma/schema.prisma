// FreelanceHigh — Prisma Schema (Production)
// Source unique de verite pour tous les types DB

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──

enum UserRole {
  FREELANCE
  CLIENT
  AGENCE
  ADMIN
}

enum UserPlan {
  GRATUIT
  PRO
  BUSINESS
  AGENCE
}

enum UserStatus {
  ACTIF
  SUSPENDU
  BANNI
}

enum ServiceStatus {
  BROUILLON
  EN_ATTENTE
  ACTIF
  PAUSE
  REFUSE
  VEDETTE
}

enum OrderStatus {
  EN_ATTENTE
  EN_COURS
  LIVRE
  REVISION
  TERMINE
  ANNULE
  LITIGE
}

enum EscrowStatus {
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

enum PaymentStatus {
  EN_ATTENTE
  COMPLETE
  ECHOUE
  REMBOURSE
}

enum PaymentMethod {
  CARTE
  MOBILE_MONEY
  VIREMENT
  PAYPAL
  STRIPE
}

enum DisputeStatus {
  OUVERT
  EN_EXAMEN
  RESOLU
}

enum DisputeVerdict {
  CLIENT
  FREELANCE
  PARTIEL
  ANNULATION
}

enum ConversationType {
  DIRECT
  GROUP
  ORDER
  ADMIN
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
  VOICE
  CALL_AUDIO
  CALL_VIDEO
  CALL_MISSED
}

enum NotificationType {
  ADMIN_ACTION
  MESSAGE
  ORDER
  KYC
  SYSTEM
  PAYMENT
  OFFER
  REVIEW
  AGENCY
  PRODUCT
  SERVICE
  BOOST
}



enum BlogStatus {
  BROUILLON
  PROGRAMME
  PUBLIE
}

enum BidStatus {
  EN_ATTENTE
  ACCEPTE
  REFUSE
  EXPIRE
}

enum OfferStatus {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
  EXPIREE
  ANNULEE
}



enum AutomationStatus {
  ACTIF
  PAUSE
  BROUILLON
}

enum PropositionStatus {
  PENDING
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum BoostType {
  VIEWS_BOOST
  FEATURED
  PREMIUM
}

enum BoostStatus {
  PENDING_PAYMENT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum EscrowReason {
  ORDER_PAYMENT
  BOOST_PAYMENT
}

enum TransactionType {
  SERVICE_FEE
  BOOST_FEE
  SUBSCRIPTION_FEE
  REFUND
  PAYOUT
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  PAID_OUT
}

enum PayoutStatus {
  PAYOUT_PENDING
  PROCESSING
  PAYOUT_COMPLETED
  FAILED
}

enum TeamMemberRole {
  PROPRIETAIRE
  MANAGER
  FREELANCE_MEMBRE
  COMMERCIAL
}

enum TeamMemberStatus {
  INVITED
  ACTIVE
  INACTIVE
  REMOVED
}

enum WalletTransactionType {
  ORDER_PAYOUT
  REFUND_WALLET
  WITHDRAWAL
  DEPOSIT
  BOOST_REFUND
  COMMISSION_INTERNAL
}

enum WalletTransactionStatus {
  WALLET_PENDING
  WALLET_COMPLETED
  WALLET_FAILED
  WALLET_CANCELLED
}

enum WithdrawalMethod {
  SEPA
  MOBILE_MONEY
  PAYPAL
  WISE
  CRYPTO
}

// ── OTP Codes ──

model OtpCode {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ── Models ──

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  emailVerified   DateTime?
  passwordHash    String
  name            String
  image           String?
  role            UserRole   @default(CLIENT)
  plan            UserPlan   @default(GRATUIT)
  status          UserStatus @default(ACTIF)
  country         String?
  countryFlag     String?
  avatar          String?
  kyc             Int        @default(1)
  suspendReason   String?

  // Personal info (KYC verification)
  firstName       String?
  lastName        String?
  city            String?
  address         String?
  dateOfBirth     DateTime?

  // 2FA
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?



  // Tracking
  lastLoginAt     DateTime?
  lastLoginIp     String?
  loginCount      Int        @default(0)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  accounts           Account[]
  sessions           Session[]
  auditLogsAsActor   AuditLog[]          @relation("AuditActor")
  auditLogsAsTarget  AuditLog[]          @relation("AuditTarget")
  messages           Message[]
  notifications      Notification[]
  conversationUsers  ConversationUser[]
  loginAttempts      LoginAttempt[]
  freelancerProfile  FreelancerProfile?
  clientProfile      ClientProfile?
  agencyProfile      AgencyProfile?
  services           Service[]
  ordersAsClient     Order[]             @relation("OrderClient")
  ordersAsFreelance  Order[]             @relation("OrderFreelance")
  reviewsGiven       Review[]            @relation("ReviewAuthor")
  reviewsReceived    Review[]            @relation("ReviewTarget")
  paymentsAsPayer    Payment[]           @relation("PaymentPayer")
  paymentsAsPayee    Payment[]           @relation("PaymentPayee")
  bids               Bid[]
  contractsSigned    ContractSignature[]
  automations        AutomationScenario[]
  affiliationCodes   AffiliationCode[]
  blogPosts          BlogPost[]
  kycRequests        KycRequest[]
  disputesAsClient   Dispute[]           @relation("DisputeClient")
  disputesAsFreelance Dispute[]          @relation("DisputeFreelance")
  projects           Project[]           @relation("ProjectClient")
  bidsOnProjects     ProjectBid[]        @relation("ProjectBidFreelance")


  offers               Offer[]                  @relation("UserOffers")
  offersReceived       Offer[]                  @relation("OffersReceived")

  // Relations Phase 1 — données correctement liées
  propositionsAsFreelance Proposition[]          @relation("PropositionFreelance")
  propositionsAsClient    Proposition[]          @relation("PropositionClient")
  boosts                  Boost[]                @relation("UserBoosts")
  serviceViews            ServiceView[]
  serviceClicks           ServiceClick[]
  teamMemberships         TeamMember[]
  walletFreelance         WalletFreelance?

  @@index([email])
  @@index([role])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model FreelancerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  bio              String?  @db.Text
  title            String?
  skills           String[] @default([])
  hourlyRate       Float?
  availability     Json?
  timezone         String?
  languages        Json?
  portfolio        Json?
  badges           String[] @default([])
  completionRate   Float    @default(0)
  completionPercent Float   @default(0)
  avgResponseTime  Int?
  phone            String?
  coverPhoto       String?
  city             String?
  country          String?
  education        Json?
  links            Json?
  vacationMode     Boolean  @default(false)

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  company     String?
  sector      String?
  size        String?  // "1-10", "11-50", "51-200", "200+"
  website     String?
  description String?  @db.Text

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgencyProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  agencyName  String
  logo        String?
  sector      String?
  size        String?
  description String?  @db.Text
  website     String?
  siret       String?
  verified    Boolean  @default(false)
  teamMembers Json?    // Array d'objets { userId, role, joinedAt } (legacy)
  settings    Json?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  members        TeamMember[]
  agServices     Service[]     @relation("AgencyServices")
  agOrders       Order[]       @relation("AgencyOrders")
  agPropositions Proposition[] @relation("AgencyPropositions")
  agBoosts       Boost[]       @relation("AgencyBoosts")
  wallet         WalletAgency?
}

model TeamMember {
  id          String           @id @default(cuid())
  agencyId    String
  userId      String
  role        TeamMemberRole   @default(FREELANCE_MEMBRE)
  status      TeamMemberStatus @default(INVITED)
  joinedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  agency      AgencyProfile    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
  @@index([agencyId])
  @@index([userId])
}

model WalletFreelance {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Float    @default(0)
  pending     Float    @default(0)
  totalEarned Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[] @relation("FreelanceWalletTx")
}

model WalletAgency {
  id          String   @id @default(cuid())
  agencyId    String   @unique
  balance     Float    @default(0)
  pending     Float    @default(0)
  totalEarned Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agency       AgencyProfile      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[] @relation("AgencyWalletTx")
}

model WalletTransaction {
  id                  String                  @id @default(cuid())
  freelanceWalletId   String?
  agencyWalletId      String?
  type                WalletTransactionType
  amount              Float
  description         String
  status              WalletTransactionStatus @default(WALLET_PENDING)
  orderId             String?
  withdrawalMethod    WithdrawalMethod?
  externalRef         String?
  createdAt           DateTime                @default(now())

  freelanceWallet     WalletFreelance?        @relation("FreelanceWalletTx", fields: [freelanceWalletId], references: [id])
  agencyWallet        WalletAgency?           @relation("AgencyWalletTx", fields: [agencyWalletId], references: [id])

  @@index([freelanceWalletId])
  @@index([agencyWalletId])
  @@index([status])
}

model Session {
  id              String   @id @default(cuid())
  userId          String
  token           String   @unique
  ipAddress       String?
  userAgent       String?
  expiresAt       DateTime
  isImpersonation Boolean  @default(false)
  impersonatedBy  String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  color       String?
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  parentId    String?
  parent      Category? @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  services    Service[]
  tags        Tag[]
  createdAt   DateTime @default(now())

  @@index([slug])
  @@index([order])
}

enum MediaType {
  IMAGE
  VIDEO
}

model Service {
  id                   String        @id @default(cuid())
  title                String
  slug                 String        @unique
  language             String        @default("fr")
  description          Json?         // Format Tiptap JSON
  descriptionText      String?       @db.Text // Texte brut pour la recherche FTS
  categoryId           String
  subCategoryId        String?
  userId               String
  agencyId             String?
  status               ServiceStatus @default(BROUILLON)
  basePrice            Float         @default(5)
  deliveryDays         Int           @default(7)
  revisions            Int           @default(1)
  instructionsRequired Boolean       @default(false)
  instructionsContent  Json?         // Format Tiptap JSON
  draftData            Json?         // Sauvegarde brouillon wizard complet
  draftStep            Int?          // Derniere etape completee du wizard

  // Ancien champ prix conserve pour compatibilite
  price                Float         @default(5)

  // Legacy fields (migration progressive)
  tags                 String[]      @default([])
  images               String[]      @default([])
  packages             Json?
  faq                  Json?
  extras               Json?

  // Stats — liées aux vraies données
  // totalOrders = COUNT(Order WHERE status=TERMINE)
  // totalRevenue = SUM(Order.freelancerPayout WHERE status=TERMINE)
  // totalViews = COUNT(ServiceView)
  // totalClicks = COUNT(ServiceClick)
  views                Int           @default(0)
  orderCount           Int           @default(0)
  totalRevenue         Float         @default(0)
  totalContacts        Int           @default(0)
  rating               Float         @default(0)
  ratingCount          Int           @default(0)
  isBoosted            Boolean       @default(false)
  boostedUntil         DateTime?
  refuseReason         String?

  // SEO complet
  seoTitle             String?
  seoDescription       String?
  seoKeywords          String[]      @default([])
  seoFocusKeyword      String?
  seoLongTail          String[]      @default([])
  seoMetaTitle         String?
  seoMetaDescription   String?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relations
  category             Category      @relation(fields: [categoryId], references: [id])
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders               Order[]
  reviews              Review[]
  options              ServiceOption[]
  media                ServiceMedia[]
  serviceTags          ServiceTag[]
  propositions         Proposition[]
  boosts               Boost[]
  viewTracking         ServiceView[]
  clickTracking        ServiceClick[]
  agency               AgencyProfile? @relation("AgencyServices", fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([categoryId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@index([agencyId])
}

model ServiceOption {
  id                  String   @id @default(cuid())
  serviceId           String
  title               String
  description         String?
  extraPrice          Float    @default(0)
  extraDays           Int      @default(0)
  isRecommended       Boolean  @default(false)
  sortOrder           Int      @default(0)
  expressEnabled      Boolean  @default(false)
  expressPrice        Float?
  expressDaysReduction Int?

  createdAt           DateTime @default(now())

  service             Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([sortOrder])
}

model ServiceMedia {
  id          String    @id @default(cuid())
  serviceId   String
  type        MediaType @default(IMAGE)
  url         String
  isPrimary   Boolean   @default(false)
  sortOrder   Int       @default(0)
  width       Int?
  height      Int?

  createdAt   DateTime  @default(now())

  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([isPrimary])
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  categoryId  String?

  category    Category?    @relation(fields: [categoryId], references: [id])
  services    ServiceTag[]

  @@index([categoryId])
  @@index([slug])
}

model ServiceTag {
  serviceId   String
  tagId       String

  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tag         Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([serviceId, tagId])
  @@index([tagId])
}

// ── Projets clients (offres publiées par les clients) ──────────────────────
model Project {
  id            String        @id @default(cuid())
  clientId      String
  title         String
  description   String        @db.Text
  category      String        @default("general")
  budgetMin     Float         @default(0)
  budgetMax     Float         @default(0)
  deadline      DateTime
  urgency       String        @default("normale") // normale, urgente, tres_urgente
  contractType  String        @default("ponctuel") // ponctuel, long_terme, recurrent
  skills        String[]      @default([])
  status        String        @default("ouvert") // ouvert, pourvu, ferme, brouillon
  visibility    String        @default("public") // public, prive

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  client        User          @relation("ProjectClient", fields: [clientId], references: [id], onDelete: Cascade)
  bids          ProjectBid[]
  propositions  Proposition[]

  @@index([clientId])
  @@index([status])
  @@index([category])
}

model ProjectBid {
  id            String   @id @default(cuid())
  projectId     String
  freelanceId   String
  amount        Float
  deliveryDays  Int
  coverLetter   String?  @db.Text
  status        String   @default("en_attente") // en_attente, acceptee, refusee

  createdAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelance     User     @relation("ProjectBidFreelance", fields: [freelanceId], references: [id])

  @@index([projectId])
  @@index([freelanceId])
}

model Order {
  id            String       @id @default(cuid())
  serviceId     String?
  clientId      String
  freelanceId   String
  agencyId      String?
  status        OrderStatus  @default(EN_ATTENTE)
  escrowStatus  EscrowStatus @default(HELD)
  amount        Float
  currency      String       @default("EUR")

  // Commission calculée automatiquement
  // platformFee = 20% de amount (va à Admin)
  // freelancerPayout = 80% de amount (au freelancer)
  commission    Float        @default(0)
  platformFee   Float        @default(0)
  freelancerPayout Float     @default(0)

  title         String?
  description   String?      @db.Text
  deliveryDays  Int?
  packageType   String?      // "basic", "standard", "premium"
  requirements  String?      @db.Text
  progress      Int          @default(0)

  // Timeline complète
  deadline      DateTime
  deliveredDeadline DateTime?
  acceptedAt    DateTime?
  startedAt     DateTime?
  deliveredAt   DateTime?
  completedAt   DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  service       Service?     @relation(fields: [serviceId], references: [id])
  client        User         @relation("OrderClient", fields: [clientId], references: [id])
  freelance     User         @relation("OrderFreelance", fields: [freelanceId], references: [id])
  payments      Payment[]
  reviews       Review[]
  disputes      Dispute[]
  conversation  Conversation?
  escrow        Escrow?
  revisions     RevisionRequest[]
  proposition   Proposition?
  agency        AgencyProfile? @relation("AgencyOrders", fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([freelanceId])
  @@index([agencyId])
  @@index([status])
  @@index([createdAt])
}

model Review {
  id          String   @id @default(cuid())
  orderId     String
  serviceId   String
  authorId    String
  targetId    String
  rating      Float
  comment     String?  @db.Text
  response    String?  @db.Text // reponse du freelance
  quality     Float?
  communication Float?
  timeliness  Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order       Order    @relation(fields: [orderId], references: [id])
  service     Service  @relation(fields: [serviceId], references: [id])
  author      User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  target      User     @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([orderId, authorId])
  @@index([targetId])
  @@index([serviceId])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String?
  payerId         String
  payeeId         String?
  amount          Float
  currency        String        @default("EUR")
  status          PaymentStatus @default(EN_ATTENTE)
  method          PaymentMethod?
  stripePaymentId String?
  description     String?
  type            String        @default("paiement") // paiement, commission, retrait, remboursement, abonnement

  createdAt       DateTime      @default(now())

  order           Order?        @relation(fields: [orderId], references: [id])
  payer           User          @relation("PaymentPayer", fields: [payerId], references: [id])
  payee           User?         @relation("PaymentPayee", fields: [payeeId], references: [id])

  @@index([orderId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
}

model Dispute {
  id              String         @id @default(cuid())
  orderId         String
  clientId        String
  freelanceId     String
  reason          String
  clientArgument  String?        @db.Text
  freelanceArgument String?      @db.Text
  status          DisputeStatus  @default(OUVERT)
  verdict         DisputeVerdict?
  verdictNote     String?
  partialPercent  Int?
  resolvedAt      DateTime?

  createdAt       DateTime       @default(now())

  order           Order          @relation(fields: [orderId], references: [id])
  client          User           @relation("DisputeClient", fields: [clientId], references: [id])
  freelance       User           @relation("DisputeFreelance", fields: [freelanceId], references: [id])

  @@index([status])
  @@index([orderId])
}

model Bid {
  id          String    @id @default(cuid())
  userId      String
  projectId   String?   // reference a un projet client (future table)
  proposal    String?   @db.Text
  amount      Float
  deliveryDays Int
  status      BidStatus @default(EN_ATTENTE)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Offer {
  id            String       @id @default(cuid())
  freelanceId   String
  clientId      String?
  clientName    String
  clientEmail   String?
  title         String
  description   String       @db.Text
  amount        Float
  delay         String       // ex: "7 jours", "2 semaines"
  revisions     Int          @default(2)
  validityDays  Int          @default(14)
  status        OfferStatus  @default(EN_ATTENTE)
  expiresAt     DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  freelance     User         @relation("UserOffers", fields: [freelanceId], references: [id], onDelete: Cascade)
  client        User?        @relation("OffersReceived", fields: [clientId], references: [id])

  @@index([freelanceId])
  @@index([clientId])
  @@index([status])
}

model Contract {
  id          String         @id @default(cuid())
  title       String
  content     String         @db.Text
  orderId     String?
  status      ContractStatus @default(BROUILLON)
  expiresAt   DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  signatures  ContractSignature[]
}

model ContractSignature {
  id          String   @id @default(cuid())
  contractId  String
  userId      String
  signedAt    DateTime @default(now())
  ipAddress   String?

  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@unique([contractId, userId])
}

model AutomationScenario {
  id            String           @id @default(cuid())
  userId        String
  name          String
  trigger       String           // "order_accepted", "deadline_24h", "client_inactive_3d"
  conditions    Json?            // conditions supplementaires
  actions       Json             // actions a executer
  status        AutomationStatus @default(BROUILLON)
  planRequired  UserPlan         @default(PRO) // plan minimum requis
  executionCount Int             @default(0)
  lastExecutedAt DateTime?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AffiliationCode {
  id          String   @id @default(cuid())
  userId      String
  code        String   @unique
  commission  Float    @default(10) // pourcentage
  tier        String   @default("standard") // standard, premium
  usageCount  Int      @default(0)
  totalEarned Float    @default(0)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     String     @db.Text
  excerpt     String?
  coverImage  String?
  category    String?
  tags        String[]   @default([])
  authorId    String
  status      BlogStatus @default(BROUILLON)
  publishedAt DateTime?
  scheduledAt DateTime?
  views       Int        @default(0)

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  author      User       @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
}

model KycRequest {
  id              String    @id @default(cuid())
  userId          String
  requestedLevel  Int
  currentLevel    Int
  documentType    String
  documentUrl     String?
  status          KycStatus @default(EN_ATTENTE)
  reviewedBy      String?
  reviewedAt      DateTime?
  refuseReason    String?
  metadata        Json?
  submissionType  String?

  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorId       String
  action        String
  targetType    String?
  targetId      String?
  targetUserId  String?
  details       Json?
  ipAddress     String?

  createdAt     DateTime @default(now())

  actor         User     @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser    User?    @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType @default(DIRECT)
  title     String?
  orderId   String?          @unique

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  order     Order?           @relation(fields: [orderId], references: [id])
  users     ConversationUser[]
  messages  Message[]

  @@index([type])
}

model ConversationUser {
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  senderId        String
  content         String       @db.Text
  type            MessageType  @default(TEXT)
  fileName        String?
  fileUrl         String?
  fileType        String?
  fileSizeBytes   Int?
  audioUrl        String?
  audioDuration   Int?
  transcription   String?      @db.Text
  callDuration    Int?
  read            Boolean      @default(false)

  editedAt        DateTime?
  deletedAt       DateTime?
  linkPreviewData Json?

  createdAt       DateTime     @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  read      Boolean          @default(false)
  link      String?

  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

// ── Admin Team Invitations (magic link) ──

model AdminInvitation {
  id        String   @id @default(cuid())
  email     String
  name      String
  adminRole String
  token     String   @unique
  status    String   @default("pending") // pending | accepted | expired
  invitedBy String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// ── Platform Configuration (key-value store) ──

model PlatformConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ── Admin Notification Log ──

model AdminNotificationLog {
  id              String   @id @default(cuid())
  adminId         String
  title           String
  message         String   @db.Text
  targetCriteria  Json?
  recipientCount  Int      @default(0)
  failedCount     Int      @default(0)
  channels        String[] @default([])
  createdAt       DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════
// PHASE 1 — DONNÉES CORRECTEMENT LIÉES
// Tracking, Propositions, Boosts, Escrow, Admin Wallet
// ══════════════════════════════════════════════════════════════

// ── Tracking réel des vues et clics service ──

model ServiceView {
  id        String   @id @default(cuid())
  serviceId String
  userId    String?
  ip        String?
  createdAt DateTime @default(now())

  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([userId])
  @@index([createdAt])
}

model ServiceClick {
  id        String   @id @default(cuid())
  serviceId String
  userId    String?
  ip        String?
  createdAt DateTime @default(now())

  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([userId])
  @@index([createdAt])
}

// ── Propositions (offres basées sur un service) ──

model Proposition {
  id          String            @id @default(cuid())

  serviceId   String
  freelanceId String
  clientId    String
  agencyId    String?
  projectId   String?

  title       String
  description String            @db.Text
  amount      Float
  deliveryDays Int
  revisions   Int               @default(1)

  status      PropositionStatus @default(PENDING)

  viewedAt    DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?
  expiresAt   DateTime?

  // Devient commande si acceptée
  orderId     String?           @unique

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  service     Service           @relation(fields: [serviceId], references: [id])
  freelance   User              @relation("PropositionFreelance", fields: [freelanceId], references: [id])
  client      User              @relation("PropositionClient", fields: [clientId], references: [id])
  project     Project?          @relation(fields: [projectId], references: [id])
  order       Order?            @relation(fields: [orderId], references: [id])
  agency      AgencyProfile?    @relation("AgencyPropositions", fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([freelanceId])
  @@index([clientId])
  @@index([agencyId])
  @@index([status])
}

// ── Demandes de révision sur une commande ──

model RevisionRequest {
  id          String   @id @default(cuid())
  orderId     String
  requestedBy String
  message     String   @db.Text
  status      String   @default("pending") // pending, resolved
  resolvedAt  DateTime?

  createdAt   DateTime @default(now())

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

// ── Boosts (promotions payantes de services) ──

model Boost {
  id          String      @id @default(cuid())

  serviceId   String
  userId      String
  agencyId    String?

  type        BoostType
  durationDays Int
  costPerDay  Float
  totalCost   Float

  // Estimations
  estimatedDailyImpressions Int @default(0)
  totalEstimatedImpressions Int @default(0)

  // Stats réelles (non simulées)
  // actualImpressions = SUM(BoostDailyStat.impressions)
  // actualClicks = SUM(BoostDailyStat.clicks)
  actualImpressions Int @default(0)
  actualClicks      Int @default(0)
  actualContacts    Int @default(0)
  actualOrders      Int @default(0)

  status      BoostStatus @default(PENDING_PAYMENT)

  paidAt      DateTime?
  startedAt   DateTime?
  endedAt     DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  service     Service     @relation(fields: [serviceId], references: [id])
  user        User        @relation("UserBoosts", fields: [userId], references: [id])
  escrow      Escrow?
  dailyStats  BoostDailyStat[]
  agency      AgencyProfile?  @relation("AgencyBoosts", fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([userId])
  @@index([agencyId])
  @@index([status])
}

model BoostDailyStat {
  id          String   @id @default(cuid())
  boostId     String
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  contacts    Int      @default(0)
  orders      Int      @default(0)

  boost       Boost    @relation(fields: [boostId], references: [id], onDelete: Cascade)

  @@unique([boostId, date])
  @@index([boostId])
  @@index([date])
}

// ── Escrow (paiement bloqué — ordres et boosts) ──

model Escrow {
  id        String       @id @default(cuid())

  orderId   String?      @unique
  boostId   String?      @unique

  amount    Float
  currency  String       @default("EUR")
  reason    EscrowReason
  status    EscrowStatus @default(HELD)

  heldAt    DateTime     @default(now())
  releasedAt DateTime?

  order     Order?       @relation(fields: [orderId], references: [id])
  boost     Boost?       @relation(fields: [boostId], references: [id])

  @@index([orderId])
  @@index([boostId])
  @@index([status])
}

// ── Admin Wallet (toutes les commissions plateforme) ──

model AdminWallet {
  id                String             @id @default(cuid())

  // Montants totaux réels
  totalFeesHeld     Float              @default(0)
  totalFeesReleased Float              @default(0)

  transactions      AdminTransaction[]
  payouts           AdminPayout[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model AdminTransaction {
  id            String            @id @default(cuid())
  adminWalletId String

  type          TransactionType
  amount        Float
  currency      String            @default("EUR")
  description   String

  orderId       String?
  boostId       String?

  status        TransactionStatus @default(PENDING)

  createdAt     DateTime          @default(now())

  adminWallet   AdminWallet       @relation(fields: [adminWalletId], references: [id])

  @@index([adminWalletId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model AdminPayout {
  id            String      @id @default(cuid())
  adminWalletId String

  amount        Float
  currency      String      @default("EUR")
  method        String
  status        PayoutStatus @default(PAYOUT_PENDING)

  paidAt        DateTime?

  createdAt     DateTime    @default(now())

  adminWallet   AdminWallet @relation(fields: [adminWalletId], references: [id])

  @@index([adminWalletId])
  @@index([status])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════
// MARKETING SYSTEM — Affiliate, Discounts, Email Automation,
// Funnels, Popups, Campaigns, Analytics, Automation Engine
// ══════════════════════════════════════════════════════════════

// ── Enums ─────────────────────────────────────────────────────

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DiscountScope {
  ALL
  FORMATIONS
  PRODUCTS
  SPECIFIC
}

enum EmailSequenceTrigger {
  PURCHASE
  ENROLLMENT
  ABANDONED_CART
  USER_INACTIVITY
  COURSE_COMPLETION
  SIGNUP
  MANUAL
  TAG_ADDED
}

enum EmailStepType {
  EMAIL
  DELAY
  CONDITION
  TAG_ACTION
}

enum SequenceEnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum FunnelStepType {
  LANDING
  PRODUCT
  CHECKOUT
  UPSELL
  DOWNSELL
  CONFIRMATION
  THANK_YOU
}

enum PopupTrigger {
  EXIT_INTENT
  TIME_DELAY
  SCROLL_PERCENT
  PAGE_VIEW_COUNT
  MANUAL
}

enum PopupType {
  DISCOUNT
  EMAIL_CAPTURE
  ANNOUNCEMENT
  UPSELL
  COUNTDOWN
}

enum AutomationTriggerType {
  PURCHASE
  ENROLLMENT
  CART_ABANDONED
  COURSE_COMPLETED
  LESSON_COMPLETED
  QUIZ_PASSED
  QUIZ_FAILED
  USER_SIGNUP
  USER_INACTIVE
  TAG_ADDED
  TAG_REMOVED
  AFFILIATE_SALE
  FUNNEL_STEP_REACHED
  CUSTOM_EVENT
}

enum AutomationActionType {
  SEND_EMAIL
  ADD_TAG
  REMOVE_TAG
  ENROLL_SEQUENCE
  CANCEL_SEQUENCE
  GRANT_ACCESS
  REVOKE_ACCESS
  SEND_NOTIFICATION
  WEBHOOK
  DELAY
  CONDITION_CHECK
  CREATE_DISCOUNT
  TRIGGER_UPSELL
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

// ── Affiliate System ──────────────────────────────────────────

model AffiliateProgram {
  id               String             @id @default(cuid())
  instructeurId    String
  name             String
  description      String?            @db.Text
  commissionPct    Float              @default(20)    // default 20%
  cookieDays       Int                @default(30)    // tracking cookie duration
  isActive         Boolean            @default(true)
  minPayoutAmount  Float              @default(20)    // minimum €20 for payout
  autoApprove      Boolean            @default(true)  // auto-approve affiliates
  // Scope: which products/courses
  applyToAll       Boolean            @default(true)
  formationIds     String[]           @default([])
  productIds       String[]           @default([])

  instructeur      InstructeurProfile @relation("InstructeurAffiliatePrograms", fields: [instructeurId], references: [id], onDelete: Cascade)
  affiliates       AffiliateProfile[]

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([instructeurId])
  @@index([isActive])
}

model AffiliateProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  programId        String
  affiliateCode    String           @unique  // unique code for links
  status           AffiliateStatus  @default(PENDING)
  totalClicks      Int              @default(0)
  totalConversions Int              @default(0)
  totalEarned      Float            @default(0)
  pendingEarnings  Float            @default(0)
  paidEarnings     Float            @default(0)
  conversionRate   Float            @default(0)
  paypalEmail      String?
  bankDetails      Json?

  user             User             @relation("UserAffiliateProfile", fields: [userId], references: [id], onDelete: Cascade)
  program          AffiliateProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  clicks           AffiliateClick[]
  commissions      AffiliateCommission[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId])
  @@index([programId])
  @@index([affiliateCode])
  @@index([status])
}

model AffiliateClick {
  id            String           @id @default(cuid())
  affiliateId   String
  visitorId     String?          // anonymous visitor ID (cookie)
  userId        String?          // if visitor is logged in
  ip            String?
  userAgent     String?
  referer       String?
  landingPage   String?
  converted     Boolean          @default(false)
  conversionId  String?          // link to commission

  affiliate     AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  user          User?            @relation("UserAffiliateClicks", fields: [userId], references: [id], onDelete: SetNull)

  createdAt     DateTime         @default(now())

  @@index([affiliateId])
  @@index([visitorId])
  @@index([userId])
  @@index([createdAt])
  @@index([converted])
}

model AffiliateCommission {
  id              String          @id @default(cuid())
  affiliateId     String
  orderId         String?         // enrollment or purchase reference
  orderType       String          // "formation" or "product"
  orderAmount     Float           // total sale amount
  commissionPct   Float           // % at time of sale
  commissionAmount Float          // calculated amount
  status          CommissionStatus @default(PENDING)
  paidAt          DateTime?
  payoutRef       String?         // payout transaction reference

  affiliate       AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([affiliateId])
  @@index([status])
  @@index([createdAt])
}

// ── Discount System ───────────────────────────────────────────

model DiscountCode {
  id              String           @id @default(cuid())
  instructeurId   String
  code            String           @unique
  discountType    DiscountType     @default(PERCENTAGE)
  discountValue   Float            // percentage (0-100) or fixed amount
  scope           DiscountScope    @default(ALL)
  formationIds    String[]         @default([])
  productIds      String[]         @default([])
  maxUses         Int?             // null = unlimited
  usedCount       Int              @default(0)
  maxUsesPerUser  Int?             // null = unlimited
  minOrderAmount  Float?           // minimum order value
  expiresAt       DateTime?
  isActive        Boolean          @default(true)
  // Tracking
  totalDiscounted Float            @default(0) // total amount discounted
  revenue         Float            @default(0) // total revenue from discounted sales

  instructeur     InstructeurProfile @relation("InstructeurDiscountCodes", fields: [instructeurId], references: [id], onDelete: Cascade)
  usages          DiscountUsage[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([code])
  @@index([instructeurId])
  @@index([isActive])
  @@index([expiresAt])
}

model DiscountUsage {
  id            String       @id @default(cuid())
  discountId    String
  userId        String
  orderType     String       // "formation" or "product"
  orderId       String
  originalAmount Float
  discountAmount Float
  finalAmount   Float

  discount      DiscountCode @relation(fields: [discountId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())

  @@index([discountId])
  @@index([userId])
  @@unique([discountId, userId, orderId])
}

// ── Email Automation System ───────────────────────────────────

model EmailSequence {
  id              String              @id @default(cuid())
  instructeurId   String
  name            String
  description     String?             @db.Text
  trigger         EmailSequenceTrigger
  triggerConfig   Json?               // additional trigger config (e.g., days of inactivity)
  isActive        Boolean             @default(false)
  totalEnrolled   Int                 @default(0)
  totalCompleted  Int                 @default(0)

  instructeur     InstructeurProfile  @relation("InstructeurEmailSequences", fields: [instructeurId], references: [id], onDelete: Cascade)
  steps           EmailSequenceStep[]
  enrollments     EmailSequenceEnrollment[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([instructeurId])
  @@index([trigger])
  @@index([isActive])
}

model EmailSequenceStep {
  id            String        @id @default(cuid())
  sequenceId    String
  stepOrder     Int
  stepType      EmailStepType @default(EMAIL)
  // For EMAIL type
  subjectFr     String?
  subjectEn     String?
  bodyFr        String?       @db.Text
  bodyEn        String?       @db.Text
  // For DELAY type
  delayMinutes  Int?          // delay in minutes (1440 = 1 day)
  // For CONDITION type
  conditionField String?      // e.g., "course_progress", "has_purchased"
  conditionOp    String?      // "gte", "eq", "contains"
  conditionValue String?
  // For TAG_ACTION type
  tagAction     String?       // "add" or "remove"
  tagName       String?

  sequence      EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([sequenceId])
  @@index([stepOrder])
}

model EmailSequenceEnrollment {
  id              String                   @id @default(cuid())
  sequenceId      String
  userId          String
  currentStepIdx  Int                      @default(0)
  status          SequenceEnrollmentStatus @default(ACTIVE)
  nextStepAt      DateTime?                // when to execute next step
  completedAt     DateTime?
  metadata        Json?                    // user-specific context data

  sequence        EmailSequence            @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  user            User                     @relation("UserEmailSeqEnrollments", fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@unique([sequenceId, userId])
  @@index([sequenceId])
  @@index([userId])
  @@index([status, nextStepAt])
}

// ── Sales Funnel System ───────────────────────────────────────

model SalesFunnel {
  id              String             @id @default(cuid())
  instructeurId   String
  name            String
  slug            String             @unique
  description     String?            @db.Text
  isActive        Boolean            @default(false)
  totalViews      Int                @default(0)
  totalConversions Int               @default(0)
  totalRevenue    Float              @default(0)

  instructeur     InstructeurProfile @relation("InstructeurSalesFunnels", fields: [instructeurId], references: [id], onDelete: Cascade)
  steps           FunnelStep[]
  events          FunnelEvent[]

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([instructeurId])
  @@index([slug])
  @@index([isActive])
}

model FunnelStep {
  id              String         @id @default(cuid())
  funnelId        String
  stepOrder       Int
  stepType        FunnelStepType @default(PRODUCT)
  title           String
  // Product reference
  formationId     String?
  productId       String?
  // Config
  discountPct     Float?         // optional discount at this step
  headlineFr      String?
  headlineEn      String?
  descriptionFr   String?        @db.Text
  descriptionEn   String?        @db.Text
  ctaTextFr       String?
  ctaTextEn       String?
  // Tracking
  views           Int            @default(0)
  conversions     Int            @default(0)

  funnel          SalesFunnel    @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([funnelId])
  @@index([stepOrder])
}

model FunnelEvent {
  id            String      @id @default(cuid())
  funnelId      String
  stepId        String?
  userId        String?
  visitorId     String?
  eventType     String      // "view", "click", "purchase", "skip"
  metadata      Json?

  funnel        SalesFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  user          User?       @relation("UserFunnelEvents", fields: [userId], references: [id], onDelete: SetNull)

  createdAt     DateTime    @default(now())

  @@index([funnelId])
  @@index([stepId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

// ── Smart Popups & Conversion Tools ───────────────────────────

model SmartPopup {
  id              String             @id @default(cuid())
  instructeurId   String
  name            String
  popupType       PopupType          @default(DISCOUNT)
  trigger         PopupTrigger       @default(TIME_DELAY)
  // Trigger config
  delaySeconds    Int?               // for TIME_DELAY
  scrollPercent   Int?               // for SCROLL_PERCENT (0-100)
  pageViewCount   Int?               // for PAGE_VIEW_COUNT
  // Content
  headlineFr      String?
  headlineEn      String?
  bodyFr          String?            @db.Text
  bodyEn          String?            @db.Text
  ctaTextFr       String?
  ctaTextEn       String?
  imageBanner     String?
  // Discount link
  discountCodeId  String?
  // Email capture
  emailListTag    String?            // tag to add when email captured
  // Targeting
  showOnPages     String[]           @default([]) // empty = all pages
  excludePages    String[]           @default([])
  showToNewOnly   Boolean            @default(false)
  maxShowsPerUser Int                @default(1)
  // State
  isActive        Boolean            @default(false)
  // Stats
  totalImpressions Int               @default(0)
  totalClicks     Int                @default(0)
  totalConversions Int               @default(0)

  instructeur     InstructeurProfile @relation("InstructeurSmartPopups", fields: [instructeurId], references: [id], onDelete: Cascade)
  impressions     PopupImpression[]

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([instructeurId])
  @@index([isActive])
  @@index([popupType])
}

model PopupImpression {
  id            String     @id @default(cuid())
  popupId       String
  userId        String?
  visitorId     String?
  action        String     // "view", "click", "close", "convert"
  metadata      Json?

  popup         SmartPopup @relation(fields: [popupId], references: [id], onDelete: Cascade)
  user          User?      @relation("UserPopupImpressions", fields: [userId], references: [id], onDelete: SetNull)

  createdAt     DateTime   @default(now())

  @@index([popupId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ── Campaign Tracking ─────────────────────────────────────────

model CampaignTracker {
  id              String             @id @default(cuid())
  instructeurId   String
  name            String
  slug            String             @unique // used in URLs
  // UTM parameters
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  // Target
  destinationUrl  String
  // Stats
  totalClicks     Int                @default(0)
  totalConversions Int               @default(0)
  totalRevenue    Float              @default(0)
  isActive        Boolean            @default(true)

  instructeur     InstructeurProfile @relation("InstructeurCampaignTrackers", fields: [instructeurId], references: [id], onDelete: Cascade)
  events          CampaignEvent[]

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([instructeurId])
  @@index([slug])
  @@index([isActive])
}

model CampaignEvent {
  id            String          @id @default(cuid())
  campaignId    String
  userId        String?
  visitorId     String?
  eventType     String          // "click", "conversion", "purchase"
  ip            String?
  userAgent     String?
  referer       String?
  revenue       Float?
  metadata      Json?

  campaign      CampaignTracker @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user          User?           @relation("UserCampaignEvents", fields: [userId], references: [id], onDelete: SetNull)

  createdAt     DateTime        @default(now())

  @@index([campaignId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

// ── Marketing Popups ──────────────────────────────────────────

model MarketingPopup {
  id                    String             @id @default(cuid())
  instructeurId         String
  name                  String
  type                  String             // DISCOUNT, EMAIL_CAPTURE, ANNOUNCEMENT, UPSELL, COUNTDOWN
  trigger               String             // EXIT_INTENT, TIME_DELAY, SCROLL_PERCENT, PAGE_VIEW_COUNT, MANUAL
  triggerValue          Int?
  headlineFr            String
  headlineEn            String             @default("")
  bodyFr                String             @default("") @db.Text
  bodyEn                String             @default("") @db.Text
  ctaTextFr             String             @default("")
  ctaTextEn             String             @default("")
  imageBannerUrl        String?
  discountCode          String?
  emailCaptureTag       String?
  countdownEndsAt       DateTime?
  upsellProductId       String?
  upsellOriginalPrice   Float?
  upsellDiscountedPrice Float?
  ctaUrl                String?
  showOnPages           String[]           @default([])
  excludePages          String[]           @default([])
  newVisitorsOnly       Boolean            @default(false)
  maxShowsPerUser       Int                @default(3)
  impressions           Int                @default(0)
  clicks                Int                @default(0)
  conversions           Int                @default(0)
  isActive              Boolean            @default(true)

  instructeur           InstructeurProfile @relation("InstructeurPopups", fields: [instructeurId], references: [id], onDelete: Cascade)

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([instructeurId])
  @@index([isActive])
}

// ── Automation Engine ─────────────────────────────────────────

model AutomationWorkflow {
  id              String             @id @default(cuid())
  instructeurId   String
  name            String
  description     String?            @db.Text
  status          WorkflowStatus     @default(DRAFT)
  // Trigger
  triggerType     AutomationTriggerType
  triggerConfig   Json?              // e.g., { "formationId": "xxx", "minProgress": 80 }
  // Actions (ordered list)
  actions         Json               // AutomationActionType[] with config
  // Stats
  totalExecutions Int                @default(0)
  lastExecutedAt  DateTime?
  // Conditions
  conditions      Json?              // optional filter conditions

  instructeur     InstructeurProfile @relation("InstructeurAutomationWorkflows", fields: [instructeurId], references: [id], onDelete: Cascade)
  logs            AutomationLog[]

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([instructeurId])
  @@index([status])
  @@index([triggerType])
}

model AutomationLog {
  id            String             @id @default(cuid())
  workflowId    String
  userId        String?            // user that triggered this
  triggerEvent  String             // what triggered it
  actionsRun    Json               // list of actions executed
  success       Boolean            @default(true)
  error         String?            @db.Text
  executionMs   Int?               // execution time

  workflow      AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  createdAt     DateTime           @default(now())

  @@index([workflowId])
  @@index([createdAt])
  @@index([success])
}

// ── User Tags ─────────────────────────────────────────────────

model UserTag {
  id        String   @id @default(cuid())
  userId    String
  tag       String
  source    String?  // "automation", "manual", "email_sequence"

  user      User     @relation("UserTags", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tag])
  @@index([userId])
  @@index([tag])
}

// ── Refund Requests ──

model RefundRequest {
  id           String    @id @default(cuid())
  userId       String
  enrollmentId String
  amount       Float
  reason       String    @db.Text
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNote    String?   @db.Text
  resolvedAt   DateTime?
  resolvedBy   String?

  user         User       @relation("UserRefundRequests", fields: [userId], references: [id], onDelete: Cascade)
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())

  @@index([userId])
  @@index([enrollmentId])
  @@index([status])
  @@index([createdAt])
}

// ── Discussion Reports ──

model DiscussionReport {
  id           String  @id @default(cuid())
  userId       String
  discussionId String?
  replyId      String?
  reason       String  // spam, harassment, inappropriate, off-topic

  user         User                  @relation("UserDiscussionReports", fields: [userId], references: [id], onDelete: Cascade)
  discussion   CourseDiscussion?     @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  reply        CourseDiscussionReply? @relation("ReplyReports", fields: [replyId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@unique([userId, discussionId])
  @@index([discussionId])
  @@index([replyId])
  @@index([createdAt])
}

// ── Formations Config ──

model FormationsConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
