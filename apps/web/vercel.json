{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter=@freelancehigh/db generate && pnpm --filter=@freelancehigh/db exec prisma migrate deploy --schema prisma/schema.prisma && pnpm --filter=@freelancehigh/web build",
  "regions": ["cdg1"],
  "crons": [
    { "path": "/api/cron/lesson-start-reminder", "schedule": "0 9 * * *" },
    { "path": "/api/cron/weekly-vendor-recap",   "schedule": "0 18 * * 0" },
    { "path": "/api/cron/monthly-vendor-recap",  "schedule": "0 9 1 * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    }
  ]
}
